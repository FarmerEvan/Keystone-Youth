---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// This tells Astro to build a page for every markdown file
export async function getStaticPaths() {
  const lessonEntries = await getCollection('lessons');
  return lessonEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<BaseLayout title={entry.data.title} backLink="/lessons" backText="Archive" accentColor="#38bdf8">
    <div class="header">
        <h1>{entry.data.title}</h1>
        <p>{entry.data.scripture} | {entry.data.date}</p>
    </div>

    <div class="lesson-content">
        <Content />
    </div>
</BaseLayout>
---
import BaseLayout from '../layouts/BaseLayout.astro';
import VolunteerOpportunities from '../components/VolunteerOpportunities.astro';
import PrayerWall from '../components/PrayerWall.astro';

const eventsCsv = import.meta.env.PUBLIC_EVENTS_CSV_URL;
const kidsCsv = import.meta.env.PUBLIC_KIDS_CSV_URL;
const scriptAppUrl = import.meta.env.PUBLIC_SCRIPT_URL;
---

<BaseLayout title="Leader Hub" backLink="/" backText="Home" accentColor="#38bdf8">
    
    <div class="header" style="text-align: center; margin-bottom: 3rem;">
        <h1 style="font-size: 3rem; color: #38bdf8; margin: 0 0 10px 0;">Leader Hub</h1>
        
        <div class="memory-verse" style="background: rgba(56, 189, 248, 0.1); border-left: 4px solid #38bdf8; padding: 1.5rem; border-radius: 0 12px 12px 0; max-width: 700px; margin: 0 auto; text-align: left;">
            <h3 style="color: #38bdf8; margin: 0 0 10px 0; font-size: 1.1rem; text-transform: uppercase; letter-spacing: 1px;">Equipping the Saints</h3>
            <p style="font-size: 1.2rem; font-style: italic; margin: 0 0 10px 0; line-height: 1.6;">"Do your best to present yourself to God as one approved, a worker who does not need to be ashamed and who correctly handles the word of truth."</p>
            <p class="reference" style="font-size: 1rem; font-weight: bold; color: #cbd5e1; text-align: right; margin: 0;">- 2 Timothy 2:15</p>
        </div>
    </div>

    <div id="today-events-section" style="display: none; margin-bottom: 2rem;">
        <div class="card" style="background: rgba(239, 68, 68, 0.1); border: 2px solid #ef4444; border-radius: 16px; padding: 2rem; box-shadow: 0 10px 25px rgba(239, 68, 68, 0.2);">
            <h2 style="display: flex; align-items: center; gap: 10px; margin-top: 0; color: #ef4444; border-bottom: 1px solid rgba(239, 68, 68, 0.2); padding-bottom: 10px;">🚨 Happening Today!</h2>
            <div id="today-events-container">
            </div>
        </div>
    </div>

    <div class="grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 2rem;">
        
        <div class="card" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 2rem;">
            <h2 style="color: #f8fafc; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 10px; margin-top: 0;">🛠️ Leader Tools</h2>
            <div style="display: flex; flex-direction: column; gap: 10px; margin-top: 15px;">
                <a href="/childrens-church-signup" class="tool-btn">Children's Church Schedule</a>
                <a href="/food-schedule" class="tool-btn" style="border-color: #f59e0b; color: #f59e0b;">Youth Food Schedule</a>
                <a href="/leader-playbook" class="tool-btn">Ministry Playbook</a>
                <a href="/manage" class="tool-btn" style="border-color: #ef4444; color: #ef4444;">Admin Dashboard</a>
            </div>
        </div>

        <div class="card" style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 16px; padding: 2rem; display: flex; flex-direction: column;">
            <h2 style="display: flex; align-items: center; gap: 10px; margin-top: 0; color: #3b82f6; border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 10px;">🙏 Prayer Wall</h2>
            <p style="color: #cbd5e1; margin-bottom: 20px;">Bear one another's burdens. See how you can pray for our ministry.</p>
            
            <PrayerWall audience="Leader" />
        </div>

        <div class="card" style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 16px; padding: 2rem; display: flex; flex-direction: column;">
            <h2 style="display: flex; align-items: center; gap: 10px; margin-top: 0; color: #a855f7; border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 10px;">🤝 Serve With Us</h2>
            <p style="color: #cbd5e1; margin-bottom: 20px;">We are always looking to expand our core team! Check out current leadership openings.</p>
            
            <VolunteerOpportunities audience="Leader" />
        </div>
        
    </div>

    <div id="event-view-modal" class="modal-overlay" style="display: none; position: fixed; inset: 0; background: rgba(15, 23, 42, 0.85); backdrop-filter: blur(5px); z-index: 10000; align-items: center; justify-content: center; padding: 1rem;">
        <div class="modal-content" style="background: #1e293b; border-top: 4px solid #38bdf8; border-radius: 16px; width: 100%; max-width: 600px; max-height: 90vh; overflow-y: auto; padding: 2rem; box-shadow: 0 20px 50px rgba(0,0,0,0.8);">
            
            <h2 id="modal-ev-title" style="color: white; margin: 0 0 5px 0;">Title</h2>
            <p id="modal-ev-time" style="color: #38bdf8; font-weight: bold; margin: 0 0 15px 0;">Subtitle</p>
            
            <div id="modal-ev-desc" style="color: #cbd5e1; line-height: 1.6; margin-bottom: 20px; font-size: 0.95rem;"></div>

            <div id="modal-ev-links" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 30px;">
            </div>

            <div style="background: rgba(0,0,0,0.2); border-radius: 12px; padding: 1.5rem; border: 1px solid rgba(255,255,255,0.05); margin-bottom: 20px;">
                <h3 style="margin: 0 0 10px 0; color: #f8fafc; font-size: 1.1rem;">📝 Quick Admin Note</h3>
                <p style="margin: 0 0 15px 0; color: #94a3b8; font-size: 0.85rem;">Log attendance, supply needs, or general event feedback securely.</p>
                <textarea id="feedback-text" rows="3" placeholder="Type your note here..." style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.3); color: white; font-family: inherit; margin-bottom: 10px; resize: vertical; box-sizing: border-box;"></textarea>
                <button id="btn-submit-feedback" style="background: #38bdf8; color: #0f172a; border: none; padding: 10px 15px; border-radius: 8px; font-weight: bold; cursor: pointer; width: 100%; transition: opacity 0.2s;">Save Note</button>
            </div>

            <div style="text-align: right;">
                <button onclick="document.getElementById('event-view-modal').style.display='none'" style="background: transparent; border: 1px solid #475569; color: white; padding: 10px 20px; border-radius: 8px; cursor: pointer;">Close Window</button>
            </div>
        </div>
    </div>

</BaseLayout>

<style is:global>
    .tool-btn { display: block; padding: 12px; border: 1px solid #38bdf8; color: #38bdf8; text-decoration: none; border-radius: 8px; font-weight: bold; text-align: center; transition: all 0.3s; }
    .tool-btn:hover { background: rgba(56, 189, 248, 0.1); }
    .video-wrapper { position: relative; padding-bottom: 56.25%; height: 0; margin-top: 15px; border-radius: 8px; overflow: hidden; }
    .video-wrapper iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0; }
</style>

<script is:inline define:vars={{ EVENTS_CSV: eventsCsv, KIDS_CSV: kidsCsv, SCRIPT_URL: scriptAppUrl }}>
    let currentEventContext = "";

    function parseCsvRow(row, expectedLength) {
        const c = []; let inQuotes = false; let current = '';
        for (let i = 0; i < row.length; i++) {
            const char = row[i];
            if (char === '"') inQuotes = !inQuotes;
            else if (char === ',' && !inQuotes) { c.push(current); current = ''; }
            else current += char;
        }
        c.push(current);
        const mapped = c.map(s => s.replace(/^"|"$/g, '').trim());
        while(mapped.length < expectedLength) mapped.push('');
        return mapped;
    }

    function formatDate(raw) {
        if (!raw) return '';
        if (raw.match(/^\d{4}-\d{2}-\d{2}$/)) {
            const p = raw.split('-');
            const d = new Date(p[0], p[1]-1, p[2]);
            return d.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
        }
        try {
            const d = new Date(raw);
            if (!isNaN(d)) return d.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
        } catch(e) {}
        return raw;
    }

    function formatTime(raw) {
        if (!raw) return '';
        const str = raw.trim();
        const match = str.match(/(\d{1,2}):(\d{2})(?::\d{2})?\s*(AM|PM|am|pm)?/i);
        if (match) {
            let h = parseInt(match[1], 10);
            let m = match[2];
            let ampm = match[3] ? match[3].toLowerCase() : null;
            if (!ampm) { ampm = h >= 12 ? 'pm' : 'am'; h = h % 12 || 12; }
            return `${h}:${m}${ampm}`;
        }
        return str;
    }

    function getEventTimestamp(dateStr, timeStr, isEnd = false) {
        if (!dateStr) return 0;
        let d = new Date();
        if (dateStr.match(/^\d{4}-\d{2}-\d{2}$/)) {
            const p = dateStr.split('-');
            d = new Date(p[0], p[1]-1, p[2]);
        } else {
            d = new Date(dateStr);
            if (isNaN(d)) return 0;
        }
        if (timeStr) {
            const match = timeStr.trim().match(/(\d{1,2}):(\d{2})(?::\d{2})?\s*(AM|PM|am|pm)?/i);
            if (match) {
                let h = parseInt(match[1], 10);
                let m = parseInt(match[2], 10);
                let ampm = match[3] ? match[3].toLowerCase() : null;
                if (ampm === 'pm' && h < 12) h += 12;
                if (ampm === 'am' && h === 12) h = 0;
                d.setHours(h, m, 0, 0);
            } else { 
                if (isEnd) d.setHours(23, 59, 59, 999); else d.setHours(0,0,0,0);
            }
        } else { 
            if (isEnd) d.setHours(23, 59, 59, 999); else d.setHours(0,0,0,0);
        }
        return d.getTime();
    }

    function isToday(rawDate) {
        if(!rawDate) return false;
        let d;
        if (rawDate.match(/^\d{4}-\d{2}-\d{2}$/)) {
            const p = rawDate.split('-');
            d = new Date(p[0], p[1]-1, p[2]);
        } else { d = new Date(rawDate); }
        if (isNaN(d)) return false;
        
        const today = new Date();
        return d.getDate() === today.getDate() && d.getMonth() === today.getMonth() && d.getFullYear() === today.getFullYear();
    }

    function addViewAllButton(container, hiddenElements, totalCount, color) {
        const btn = document.createElement('button');
        btn.innerText = `View All (${totalCount}) ▾`;
        btn.style = `width: 100%; background: transparent; border: 1px dashed ${color}; color: ${color}; padding: 10px; border-radius: 8px; font-weight: bold; cursor: pointer; transition: all 0.2s; margin-top: 5px;`;
        let isExpanded = false;
        btn.onmouseover = () => { btn.style.background = 'rgba(255,255,255,0.05)'; };
        btn.onmouseout = () => { btn.style.background = 'transparent'; };
        btn.onclick = () => {
            isExpanded = !isExpanded;
            hiddenElements.forEach(el => el.style.display = isExpanded ? el.dataset.originalDisplay : 'none');
            btn.innerText = isExpanded ? `Show Less ▴` : `View All (${totalCount}) ▾`;
        };
        container.appendChild(btn);
    }

    async function loadLeaderData() {
        const fetchT = async (url) => { if(!url) return ""; const res = await fetch(`${url}${url.includes('?') ? '&' : '?'}t=${Date.now()}`); return await res.text(); };

        try {
            const [eventsText, kidsText] = await Promise.all([fetchT(EVENTS_CSV), fetchT(KIDS_CSV)]);
            
            const eventsArray = parseEvents(eventsText);
            const kidsArray = parseKids(kidsText);
            
            renderCombinedToday(eventsArray, kidsArray);

        } catch (error) {
            console.error("Failed to load leader data", error);
        }
    }

    function parseEvents(csv) {
        if(!csv) return [];
        const rows = csv.split('\n').slice(1);
        const results = [];
        const now = Date.now();
        
        rows.forEach(row => {
            if(!row.trim()) return;
            const c = parseCsvRow(row, 11);
            if (!c[4]) return; 

            const endTimestamp = getEventTimestamp(c[1], c[3] || c[2], true);
            const isPast = now > endTimestamp;

            results.push({ 
                type: 'event',
                id: c[0],
                date: c[1], timeStart: c[2], timeEnd: c[3], title: c[4], 
                desc: c[5].replace(/\\n/g, '<br>'), high: (c[6] || '').toUpperCase() === 'TRUE', 
                photo: c[7], brochure: c[8], handout: c[9], leader: c[10],
                isPast: isPast,
                timestampStart: getEventTimestamp(c[1], c[2], false) 
            });
        });
        return results;
    }

    function parseKids(csv) {
        if(!csv) return [];
        const rows = csv.split('\n').slice(1);
        const results = [];
        const now = Date.now();
        
        rows.forEach(row => {
            if(!row.trim()) return;
            const c = parseCsvRow(row, 10); 
            if (!c[4]) return; 
            
            const endTimestamp = getEventTimestamp(c[1], c[3] || c[2], true);
            if (now > endTimestamp) return;

            results.push({ 
                type: 'cc',
                id: c[0],
                date: c[1], timeStart: c[2], timeEnd: c[3], service: c[4], volunteer: c[5], 
                isFilled: (c[6]||'').toUpperCase() === 'TRUE', lesson: c[7], photo: c[8], overview: (c[9]||'').replace(/\\n/g, '<br>'),
                timestampStart: getEventTimestamp(c[1], c[2], false)
            });
        });
        return results;
    }

    function renderCombinedToday(events, kids) {
        const container = document.getElementById('today-events-container');
        container.innerHTML = '';
        let todayItems = [];

        events.forEach(ev => { if (isToday(ev.date) && !ev.isPast) todayItems.push(ev); });
        kids.forEach(cc => { if (isToday(cc.date)) todayItems.push(cc); });

        todayItems.sort((a, b) => a.timestampStart - b.timestampStart);

        if (todayItems.length > 0) {
            document.getElementById('today-events-section').style.display = 'block';
            let count = 0; let hiddenElements = [];

            todayItems.forEach(item => {
                const box = document.createElement('div');
                const timeString = item.timeEnd ? `${formatTime(item.timeStart)} - ${formatTime(item.timeEnd)}` : formatTime(item.timeStart);
                
                if (item.type === 'event') {
                    box.style = `background: rgba(0, 0, 0, 0.2); border-radius: 8px; padding: 15px; margin-bottom: 15px; border-left: 4px solid #ef4444; cursor: pointer; transition: transform 0.2s;`;
                    box.onmouseover = () => box.style.transform = "translateX(5px)";
                    box.onmouseout = () => box.style.transform = "translateX(0)";
                    
                    box.onclick = () => {
                        const links = [
                            {url: item.leader, title: "Leader Packet", subtitle: "Internal use only", icon: "🛡️", color: "#ef4444"},
                            {url: item.handout, title: "Lesson Handout", subtitle: "Student copies", icon: "✍️", color: "#facc15"},
                            {url: item.brochure, title: "Take-Home Brochure", subtitle: "Parent info", icon: "📄", color: "#fb923c"},
                            {url: item.photo, title: "Shared Photo Album", subtitle: "View & upload", icon: "📸", color: "#38bdf8"}
                        ];
                        openEventModal(item.title, `${formatDate(item.date)} • ${timeString}`, item.desc, links, `[ID:${item.id}]`);
                    };

                    box.innerHTML = `
                        <div style="color: #ef4444; font-weight: bold; font-size: 0.85rem; text-transform: uppercase; margin-bottom: 5px;">YOUTH EVENT TODAY</div>
                        <div style="color: #facc15; font-size: 0.8rem; margin-bottom: 5px;">${timeString}</div>
                        <h3 style="margin: 0 0 5px 0; color: #fff;">${item.title}</h3>
                    `;
                } else {
                    box.style = `background: rgba(0, 0, 0, 0.2); border-radius: 8px; padding: 15px; margin-bottom: 15px; border-left: 4px solid #06b6d4; cursor: pointer; transition: transform 0.2s;`;
                    box.onmouseover = () => box.style.transform = "translateX(5px)";
                    box.onmouseout = () => box.style.transform = "translateX(0)";
                    
                    box.onclick = () => {
                        const links = [
                            {url: item.lesson, title: "Lesson Material", subtitle: "View Curriculum", icon: "📺", color: "#06b6d4"},
                            {url: item.photo, title: "Shared Photo Album", subtitle: "View & upload", icon: "📸", color: "#10b981"}
                        ];
                        openEventModal(`Children's Church: ${item.service}`, `${formatDate(item.date)}`, item.overview || "Overview coming soon!", links, `[ID:${item.id}]`);
                    };

                    box.innerHTML = `
                        <div style="color: #06b6d4; font-weight: bold; font-size: 0.85rem; text-transform: uppercase; margin-bottom: 5px;">CHILDREN'S CHURCH TODAY</div>
                        <div style="color: #cbd5e1; font-size: 0.8rem; margin-bottom: 5px;">${item.service}</div>
                        <h3 style="margin: 0; color: #fff;">Children's Church</h3>
                    `;
                }
                
                if (count >= 3) {
                    box.dataset.originalDisplay = box.style.display || 'block';
                    box.style.display = 'none';
                    hiddenElements.push(box);
                }
                
                container.appendChild(box);
                count++;
            });

            if (hiddenElements.length > 0) addViewAllButton(container, hiddenElements, count, '#ef4444');
        }
    }

    function openEventModal(title, subtitle, desc, linksConfig, context) {
        currentEventContext = context;
        document.getElementById('modal-ev-title').innerText = title;
        document.getElementById('modal-ev-time').innerText = subtitle;
        document.getElementById('modal-ev-desc').innerHTML = desc;
        document.getElementById('feedback-text').value = ''; 
        document.getElementById('btn-submit-feedback').innerText = 'Save Note';

        const linksContainer = document.getElementById('modal-ev-links');
        linksContainer.innerHTML = '';

        const linkHTML = linksConfig.map(l => {
            if(!l.url || l.url.trim() === '') return '';
            return `
                <a href="${l.url}" target="_blank" style="display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: 8px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); text-decoration: none; padding: 20px 15px; border-radius: 12px; transition: all 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.transform='translateY(-3px)'" onmouseout="this.style.background='rgba(255,255,255,0.05)'; this.style.transform='translateY(0)'">
                    <span style="font-size: 2rem;">${l.icon}</span>
                    <strong style="color: ${l.color}; font-size: 1rem; margin-top: 5px;">${l.title}</strong>
                    <span style="color: #94a3b8; font-size: 0.75rem;">${l.subtitle}</span>
                </a>
            `;
        }).filter(Boolean).join('');

        linksContainer.innerHTML = linkHTML;
        document.getElementById('event-view-modal').style.display = 'flex';
    }

    document.getElementById('btn-submit-feedback').onclick = async () => {
        const text = document.getElementById('feedback-text').value.trim();
        if(!text) return alert("Please type your note first!");
        
        const btn = document.getElementById('btn-submit-feedback');
        btn.innerText = "Saving...";
        
        const params = new URLSearchParams({
            action: "submitFeedback",
            event: currentEventContext,
            feedback: text
        });

        try {
            await fetch(`${SCRIPT_URL}?${params.toString()}`, {mode:'no-cors'});
            btn.innerText = "✅ Saved!";
            setTimeout(() => { document.getElementById('event-view-modal').style.display = 'none'; }, 2000);
        } catch (e) {
            btn.innerText = "❌ Error saving";
        }
    };

    loadLeaderData();
    document.addEventListener('astro:page-load', loadLeaderData);
</script>
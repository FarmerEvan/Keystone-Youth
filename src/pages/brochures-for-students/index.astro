---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Brochure Archive" backLink="/student" backText="Student Hub" accentColor="#fb923c">

    <div class="header" style="text-align: center; margin-bottom: 2rem;">
        <h1 style="font-size: 2.8rem; color: #fb923c; margin: 0 0 10px 0;">Brochure Archive</h1>
        <p style="color: #cbd5e1; font-size: 1.1rem; line-height: 1.5;">Access all past weekly take-home brochures, challenges, and memory verses.</p>
    </div>

    <div style="margin-bottom: 2rem; text-align: center;">
        <input type="text" id="searchInput" onkeyup="searchLessons()" placeholder="Search by topic, book, or date..." style="width: 100%; max-width: 500px; padding: 15px; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.2); background: rgba(0, 0, 0, 0.3); color: white; font-size: 1.1rem; box-sizing: border-box;">
    </div>

    <div class="card" style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 16px; padding: 2rem; backdrop-filter: blur(10px);">
        
        <details class="year-folder" open style="background: rgba(0, 0, 0, 0.15); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 8px; padding: 10px; margin-bottom: 15px;">
            <summary style="cursor: pointer; font-weight: bold; color: #fb923c; font-size: 1.2rem; display: flex; align-items: center; padding: 5px;">📁 2026 Series</summary>
            
            <details class="month-folder" open style="margin-left: 20px; margin-top: 10px; border-left: 2px solid #fb923c;">
                <summary style="color: #fed7aa; font-size: 1.1rem; cursor: pointer; padding: 5px;">📂 April - The Grand Story</summary>
                
                <ul class="lesson-list" style="list-style: none; padding: 0; margin: 10px 0 0 20px;">
                    <li class="lesson-item" style="background: rgba(255, 255, 255, 0.05); margin-bottom: 8px; padding: 12px 15px; border-radius: 6px; display: flex; justify-content: space-between; align-items: center;">
                        <a href="/Burning Bush Brochure.html" style="color: #f8fafc; text-decoration: none; font-weight: 500; font-size: 1.05rem;">Out of Egypt (Exodus 1-3)</a>
                        <span style="color: #94a3b8; font-size: 0.85rem;">April 12, 2026</span>
                    </li>
                    <li class="lesson-item" style="background: rgba(255, 255, 255, 0.05); margin-bottom: 8px; padding: 12px 15px; border-radius: 6px; display: flex; justify-content: space-between; align-items: center;">
                        <a href="/Plagues Brochure.html" style="color: #f8fafc; text-decoration: none; font-weight: 500; font-size: 1.05rem;">The Plagues (Exodus 4-11)</a>
                        <span style="color: #94a3b8; font-size: 0.85rem;">April 19, 2026</span>
                    </li>
                </ul>
            </details>
        </details>

    </div>

</BaseLayout>

<script is:inline>
    function searchLessons() {
        var input = document.getElementById('searchInput').value.toLowerCase();
        var items = document.getElementsByClassName('lesson-item');
        if (input === "") {
            document.querySelectorAll('details').forEach(d => d.removeAttribute('open'));
            document.querySelector('.year-folder').setAttribute('open', 'true');
            document.querySelector('.month-folder').setAttribute('open', 'true');
        } else {
            document.querySelectorAll('details').forEach(d => d.setAttribute('open', 'true'));
        }
        for (var i = 0; i < items.length; i++) {
            var text = items[i].textContent || items[i].innerText;
            items[i].style.display = text.toLowerCase().indexOf(input) > -1 ? "flex" : "none";
        }
    }
</script>
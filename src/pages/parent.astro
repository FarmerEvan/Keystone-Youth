---
import BaseLayout from '../layouts/BaseLayout.astro';
import VolunteerOpportunities from '../components/VolunteerOpportunities.astro';
import PrayerWall from '../components/PrayerWall.astro';

const eventsCsv = import.meta.env.PUBLIC_EVENTS_CSV_URL;
const kidsCsv = import.meta.env.PUBLIC_KIDS_CSV_URL; 
const lessonsCsv = import.meta.env.PUBLIC_LESSONS_CSV_URL; 
const scriptAppUrl = import.meta.env.PUBLIC_SCRIPT_URL;
---

<BaseLayout title="Parent Hub" backLink="/" backText="Home" accentColor="#10b981">

    <div class="header" style="text-align: center; margin-bottom: 3rem;">
        <h1 style="font-size: 3rem; color: #10b981; margin: 0 0 10px 0;">Parent Hub</h1>
        
        <div class="memory-verse" style="background: rgba(16, 185, 129, 0.1); border-left: 4px solid #10b981; padding: 1.5rem; border-radius: 0 12px 12px 0; max-width: 700px; margin: 0 auto; text-align: left;">
            <h3 style="color: #10b981; margin: 0 0 10px 0; font-size: 1.1rem; text-transform: uppercase; letter-spacing: 1px;">Partnering in Discipleship</h3>
            <p style="font-size: 1.2rem; font-style: italic; margin: 0 0 10px 0; line-height: 1.6;">"These commandments that I give you today are to be on your hearts. Impress them on your children. Talk about them when you sit at home and when you walk along the road..."</p>
            <p class="reference" style="font-size: 1rem; font-weight: bold; color: #cbd5e1; text-align: right; margin: 0;">- Deuteronomy 6:6-7</p>
        </div>
    </div>

    <div id="today-events-section" style="display: none; margin-bottom: 2rem;">
        <div class="card" style="background: rgba(239, 68, 68, 0.1); border: 2px solid #ef4444; border-radius: 16px; padding: 2rem; box-shadow: 0 10px 25px rgba(239, 68, 68, 0.2);">
            <h2 style="display: flex; align-items: center; gap: 10px; margin-top: 0; color: #ef4444; border-bottom: 1px solid rgba(239, 68, 68, 0.2); padding-bottom: 10px;">🚨 Happening Today!</h2>
            <div id="today-events-container"></div>
        </div>
    </div>

    <div class="grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
        
        <div class="card" style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 16px; padding: 2rem; display: flex; flex-direction: column;">
            <h2 style="display: flex; align-items: center; gap: 10px; margin-top: 0; color: #f8fafc; border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 10px;">👦 Children's Church</h2>
            <p style="color: #cbd5e1;">Click this week's service to see the lesson overview and photos!</p>
            
            <div id="live-cc-container">
                <p style="text-align: center; color: #94a3b8; font-style: italic;">Loading services...</p>
            </div>
            
            <a href="/childrens-church-signup" style="display: block; background: transparent; border: 2px dashed #06b6d4; color: #06b6d4; padding: 10px 20px; border-radius: 8px; font-weight: bold; text-align: center; margin-top: auto; text-decoration: none; transition: background 0.2s;" onmouseover="this.style.background='rgba(6,182,212,0.1)'" onmouseout="this.style.background='transparent'">Volunteer to Help</a>
        </div>

        <div class="card" style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 16px; padding: 2rem; display: flex; flex-direction: column;">
            <h2 style="display: flex; align-items: center; gap: 10px; margin-top: 0; color: #f8fafc; border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 10px;">📖 Family Discipleship</h2>
            <p style="color: #cbd5e1; margin-bottom: 15px;">Follow along with what we are learning on Sunday nights and bring the conversation home.</p>
            <div id="family-discipleship-container" style="display: flex; flex-direction: column; flex-grow: 1;"><p style="text-align: center; color: #94a3b8; font-style: italic;">Loading this week's lesson...</p></div>
        </div>

        <div class="card" style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 16px; padding: 2rem; display: flex; flex-direction: column;">
            <h2 style="display: flex; align-items: center; gap: 10px; margin-top: 0; color: #f8fafc; border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 10px;">📅 Upcoming Youth Events</h2>
            <p style="color: #cbd5e1;">Click any event for details, brochures, and photo albums.</p>
            <div id="live-events-container"><p style="text-align: center; color: #94a3b8; font-style: italic;">Loading events...</p></div>
        </div>

        <div class="card" style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 16px; padding: 2rem; display: flex; flex-direction: column;">
            <h2 style="display: flex; align-items: center; gap: 10px; margin-top: 0; color: #f8fafc; border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 10px;">🕰️ Past Youth Events</h2>
            <p style="color: #cbd5e1;">Review past event memories and shared photo albums.</p>
            <div id="past-events-container"><p style="text-align: center; color: #94a3b8; font-style: italic;">Loading past events...</p></div>
        </div>

        <div class="card" style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 16px; padding: 2rem; display: flex; flex-direction: column;">
            <h2 style="display: flex; align-items: center; gap: 10px; margin-top: 0; color: #3b82f6; border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 10px;">🙏 Prayer Wall</h2>
            <p style="color: #cbd5e1; margin-bottom: 20px;">Bear one another's burdens. See how you can pray for our ministry.</p>
            
            <PrayerWall audience="Parent" />
        </div>

        <div class="card" style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 16px; padding: 2rem; display: flex; flex-direction: column;">
            <h2 style="display: flex; align-items: center; gap: 10px; margin-top: 0; color: #a855f7; border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 10px;">🤝 Serve With Us</h2>
            <p style="color: #cbd5e1; margin-bottom: 15px;">It takes a village! See our current volunteer openings and step into ministry with us.</p>
            
            <a href="/food-schedule" style="display: flex; align-items: center; justify-content: center; gap: 10px; background: rgba(245, 158, 11, 0.1); border: 1px dashed #f59e0b; color: #f59e0b; padding: 12px; border-radius: 8px; font-weight: bold; text-decoration: none; margin-bottom: 20px; transition: background 0.2s;" onmouseover="this.style.background='rgba(245,158,11,0.2)'" onmouseout="this.style.background='rgba(245, 158, 11, 0.1)'">
                <span style="font-size: 1.2rem;">🍕</span> View Youth Food Schedule
            </a>

            <VolunteerOpportunities audience="Parent" /> 
        </div>

    </div>

    <div id="generic-view-modal" class="modal-overlay" style="display: none; position: fixed; inset: 0; background: rgba(15, 23, 42, 0.85); backdrop-filter: blur(5px); z-index: 10000; align-items: center; justify-content: center; padding: 1rem;">
        <div class="modal-content" style="background: #1e293b; border-top: 4px solid #10b981; border-radius: 16px; width: 100%; max-width: 600px; max-height: 90vh; overflow-y: auto; padding: 2rem; box-shadow: 0 20px 50px rgba(0,0,0,0.8);">
            
            <h2 id="modal-ev-title" style="color: white; margin: 0 0 5px 0;">Title</h2>
            <p id="modal-ev-time" style="color: #10b981; font-weight: bold; margin: 0 0 15px 0;">Subtitle</p>
            
            <div id="modal-ev-desc" style="color: #cbd5e1; line-height: 1.6; margin-bottom: 20px; font-size: 0.95rem;"></div>

            <div id="modal-ev-links" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 30px;">
            </div>

            <div style="background: rgba(0,0,0,0.2); border-radius: 12px; padding: 1.5rem; border: 1px solid rgba(255,255,255,0.05); margin-bottom: 20px;">
                <h3 style="margin: 0 0 10px 0; color: #f8fafc; font-size: 1.1rem;">💬 Give Feedback</h3>
                <p style="margin: 0 0 15px 0; color: #94a3b8; font-size: 0.85rem;">Have thoughts, questions, or suggestions? Let us know!</p>
                <textarea id="feedback-text" rows="3" placeholder="Type your thoughts here..." style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.3); color: white; font-family: inherit; margin-bottom: 10px; resize: vertical; box-sizing: border-box;"></textarea>
                <button id="btn-submit-feedback" style="background: #10b981; color: white; border: none; padding: 10px 15px; border-radius: 8px; font-weight: bold; cursor: pointer; width: 100%; transition: opacity 0.2s;">Submit Feedback</button>
            </div>

            <div style="text-align: right;">
                <button onclick="document.getElementById('generic-view-modal').style.display='none'" style="background: transparent; border: 1px solid #475569; color: white; padding: 10px 20px; border-radius: 8px; cursor: pointer;">Close Window</button>
            </div>
        </div>
    </div>

</BaseLayout>

<script is:inline define:vars={{ EVENTS_URL: eventsCsv, KIDS_URL: kidsCsv, LESSONS_URL: lessonsCsv, SCRIPT_URL: scriptAppUrl }}>
    let currentFeedbackContext = "";

    function parseCsvRow(row, expectedLength) {
        const c = []; let inQuotes = false; let current = '';
        for (let i = 0; i < row.length; i++) {
            const char = row[i];
            if (char === '"') inQuotes = !inQuotes;
            else if (char === ',' && !inQuotes) { c.push(current); current = ''; }
            else current += char;
        }
        c.push(current);
        const mapped = c.map(s => s.replace(/^"|"$/g, '').trim());
        while(mapped.length < expectedLength) mapped.push('');
        return mapped;
    }

    function formatDate(raw) {
        if (!raw) return '';
        if (raw.match(/^\d{4}-\d{2}-\d{2}$/)) {
            const p = raw.split('-');
            const d = new Date(p[0], p[1]-1, p[2]);
            return d.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
        }
        try {
            const d = new Date(raw);
            if (!isNaN(d)) return d.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
        } catch(e) {}
        return raw;
    }

    function formatTime(raw) {
        if (!raw) return '';
        const str = raw.trim();
        const match = str.match(/(\d{1,2}):(\d{2})(?::\d{2})?\s*(AM|PM|am|pm)?/i);
        if (match) {
            let h = parseInt(match[1], 10);
            let m = match[2];
            let ampm = match[3] ? match[3].toLowerCase() : null;
            if (!ampm) { ampm = h >= 12 ? 'pm' : 'am'; h = h % 12 || 12; }
            return `${h}:${m}${ampm}`;
        }
        return str;
    }

    function getEventTimestamp(dateStr, timeStr, isEnd = false) {
        if (!dateStr) return 0;
        let d = new Date();
        if (dateStr.match(/^\d{4}-\d{2}-\d{2}$/)) {
            const p = dateStr.split('-');
            d = new Date(p[0], p[1]-1, p[2]);
        } else {
            d = new Date(dateStr);
            if (isNaN(d)) return 0;
        }
        if (timeStr) {
            const match = timeStr.trim().match(/(\d{1,2}):(\d{2})(?::\d{2})?\s*(AM|PM|am|pm)?/i);
            if (match) {
                let h = parseInt(match[1], 10);
                let m = parseInt(match[2], 10);
                let ampm = match[3] ? match[3].toLowerCase() : null;
                if (ampm === 'pm' && h < 12) h += 12;
                if (ampm === 'am' && h === 12) h = 0;
                d.setHours(h, m, 0, 0);
            } else { 
                if (isEnd) d.setHours(23, 59, 59, 999); else d.setHours(0,0,0,0);
            }
        } else { 
            if (isEnd) d.setHours(23, 59, 59, 999); else d.setHours(0,0,0,0);
        }
        return d.getTime();
    }

    function isToday(rawDate) {
        if(!rawDate) return false;
        let d;
        if (rawDate.match(/^\d{4}-\d{2}-\d{2}$/)) {
            const p = rawDate.split('-');
            d = new Date(p[0], p[1]-1, p[2]);
        } else { d = new Date(rawDate); }
        if (isNaN(d)) return false;
        
        const today = new Date();
        return d.getDate() === today.getDate() && d.getMonth() === today.getMonth() && d.getFullYear() === today.getFullYear();
    }

    function addViewAllButton(container, hiddenElements, totalCount, color) {
        const btn = document.createElement('button');
        btn.innerText = `View All (${totalCount}) ▾`;
        btn.style = `width: 100%; background: transparent; border: 1px dashed ${color}; color: ${color}; padding: 10px; border-radius: 8px; font-weight: bold; cursor: pointer; transition: all 0.2s; margin-top: 5px;`;
        let isExpanded = false;
        btn.onmouseover = () => { btn.style.background = 'rgba(255,255,255,0.05)'; };
        btn.onmouseout = () => { btn.style.background = 'transparent'; };
        btn.onclick = () => {
            isExpanded = !isExpanded;
            hiddenElements.forEach(el => el.style.display = isExpanded ? el.dataset.originalDisplay : 'none');
            btn.innerText = isExpanded ? `Show Less ▴` : `View All (${totalCount}) ▾`;
        };
        container.appendChild(btn);
    }

    async function loadData() {
        const fetchT = async (url) => { if(!url) return ""; const res = await fetch(`${url}${url.includes('?') ? '&' : '?'}t=${Date.now()}`); return await res.text(); };
        try {
            const [evData, kidsData, lesData] = await Promise.all([fetchT(EVENTS_URL), fetchT(KIDS_URL), fetchT(LESSONS_URL)]);
            
            const eventsArray = parseEvents(evData);
            const kidsArray = parseKids(kidsData);
            
            renderCombinedToday(eventsArray, kidsArray);
            renderStandardLists(eventsArray, kidsArray);
            renderFamilyDiscipleship(lesData);

        } catch (error) { console.error(error); }
    }

    function parseEvents(csv) {
        if(!csv) return [];
        const rows = csv.split('\n').slice(1);
        const results = [];
        const now = Date.now();
        
        rows.forEach(row => {
            if(!row.trim()) return;
            const c = parseCsvRow(row, 11);
            if (!c[4]) return; 

            const endTimestamp = getEventTimestamp(c[1], c[3] || c[2], true);
            const isPast = now > endTimestamp;

            results.push({ 
                type: 'event',
                id: c[0],
                date: c[1], timeStart: c[2], timeEnd: c[3], title: c[4], 
                desc: c[5].replace(/\\n/g, '<br>'), high: (c[6] || '').toUpperCase() === 'TRUE', 
                photo: c[7], brochure: c[8], handout: c[9], leader: c[10],
                isPast: isPast,
                timestampStart: getEventTimestamp(c[1], c[2], false) 
            });
        });
        return results;
    }

    function parseKids(csv) {
        if(!csv) return [];
        const rows = csv.split('\n').slice(1);
        const results = [];
        const now = Date.now();
        
        rows.forEach(row => {
            if(!row.trim()) return;
            const c = parseCsvRow(row, 10);
            if (!c[4]) return; 
            
            // FIXED: Looking at Date (c[1]), not ID!
            const endTimestamp = getEventTimestamp(c[1], c[3] || c[2], true);
            if (now > endTimestamp) return;

            results.push({ 
                type: 'cc',
                id: c[0],
                date: c[1], timeStart: c[2], timeEnd: c[3], service: c[4], volunteer: c[5], 
                isFilled: (c[6]||'').toUpperCase() === 'TRUE', lesson: c[7], photo: c[8], overview: (c[9]||'').replace(/\\n/g, '<br>'),
                timestampStart: getEventTimestamp(c[1], c[2], false)
            });
        });
        return results;
    }

    function renderFamilyDiscipleship(csv) {
        const container = document.getElementById('family-discipleship-container');
        if(!csv) return;
        
        const rows = csv.split('\n').slice(1);
        let activeLesson = null;
        
        const today = new Date();
        today.setHours(0,0,0,0);

        for (let i = 0; i < rows.length; i++) {
            if(!rows[i].trim()) continue;
            const c = parseCsvRow(rows[i], 6);
            if(!c[2]) continue;

            let startDate = new Date();
            if (c[0].match(/^\d{4}-\d{2}-\d{2}$/)) { const p = c[0].split('-'); startDate = new Date(p[0], p[1]-1, p[2]); } 
            else { startDate = new Date(c[0]); }
            startDate.setHours(0,0,0,0);

            let endDate = new Date();
            if (c[1].match(/^\d{4}-\d{2}-\d{2}$/)) { const p = c[1].split('-'); endDate = new Date(p[0], p[1]-1, p[2]); } 
            else { endDate = new Date(c[1]); }
            endDate.setHours(23,59,59,999);

            if (today >= startDate && today <= endDate) {
                activeLesson = { title: c[2], scripture: c[3], youtubeId: c[4], desc: c[5].replace(/\\n/g, '<br>') };
                break;
            }
        }

        if (activeLesson) {
            container.innerHTML = `
                <div style="background: rgba(0, 0, 0, 0.2); border-radius: 8px; padding: 15px; margin-bottom: 15px; border-left: 4px solid #10b981;">
                    <h3 style="margin: 0 0 5px 0; color: #fff;">Current: ${activeLesson.title}</h3>
                    <p style="margin: 0; color: #10b981; font-weight: bold; font-size: 0.85rem;">${activeLesson.scripture}</p>
                </div>
                <div style="display: flex; flex-direction: column; gap: 10px; margin-top: auto;">
                    <a href="/bible-study" style="display: block; background: #10b981; color: #0f172a; padding: 10px 20px; border-radius: 8px; font-weight: bold; text-align: center; text-decoration: none;">View This Week's Lesson</a>
                    <a href="/study-archive" style="display: block; background: transparent; border: 2px solid #10b981; color: #10b981; padding: 10px 20px; border-radius: 8px; font-weight: bold; text-align: center; text-decoration: none;">View Past Lessons Archive</a>
                </div>
            `;
        } else {
            container.innerHTML = `
                <div style="background: rgba(0, 0, 0, 0.2); border-radius: 8px; padding: 15px; margin-bottom: 15px; border-left: 4px solid #10b981;">
                    <p style="margin: 0; font-size: 0.9rem; color: #cbd5e1; line-height: 1.5; text-align: center;">No active lesson assigned for this week. Check back soon!</p>
                </div>
                <div style="display: flex; flex-direction: column; gap: 10px; margin-top: auto;">
                    <a href="/study-archive" style="display: block; background: transparent; border: 2px solid #10b981; color: #10b981; padding: 10px 20px; border-radius: 8px; font-weight: bold; text-align: center; text-decoration: none;">View Past Lessons Archive</a>
                </div>
            `;
        }
    }

    function renderCombinedToday(events, kids) {
        const container = document.getElementById('today-events-container');
        container.innerHTML = '';
        let todayItems = [];

        events.forEach(ev => { if (isToday(ev.date) && !ev.isPast) todayItems.push(ev); });
        kids.forEach(cc => { if (isToday(cc.date)) todayItems.push(cc); });

        todayItems.sort((a, b) => a.timestampStart - b.timestampStart); 

        if (todayItems.length > 0) {
            document.getElementById('today-events-section').style.display = 'block';
            let count = 0; let hiddenElements = [];
            
            todayItems.forEach(item => {
                const box = document.createElement('div');
                const timeString = item.timeEnd ? `${formatTime(item.timeStart)} - ${formatTime(item.timeEnd)}` : formatTime(item.timeStart);
                
                if (item.type === 'event') {
                    box.style = `background: rgba(0, 0, 0, 0.2); border-radius: 8px; padding: 15px; margin-bottom: 15px; border-left: 4px solid #ef4444; cursor: pointer; transition: transform 0.2s;`;
                    box.onmouseover = () => box.style.transform = "translateX(5px)";
                    box.onmouseout = () => box.style.transform = "translateX(0)";
                    
                    box.onclick = () => {
                        const links = [
                            {url: item.brochure, title: "Take-Home Brochure", subtitle: "Event details", icon: "📄", color: "#fb923c"},
                            {url: item.photo, title: "Shared Album", subtitle: "View memories", icon: "📸", color: "#38bdf8"}
                        ];
                        openModal(item.title, `${formatDate(item.date)} • ${timeString}`, item.desc, links, `[ID:${item.id}]`);
                    };

                    box.innerHTML = `
                        <div style="color: #ef4444; font-weight: bold; font-size: 0.85rem; text-transform: uppercase; margin-bottom: 5px;">YOUTH EVENT TODAY</div>
                        <div style="color: #facc15; font-size: 0.8rem; margin-bottom: 5px;">${timeString}</div>
                        <h3 style="margin: 0 0 5px 0; color: #fff;">${item.title}</h3>
                    `;
                } else {
                    box.style = `background: rgba(0, 0, 0, 0.2); border-radius: 8px; padding: 15px; margin-bottom: 15px; border-left: 4px solid #06b6d4; cursor: pointer; transition: transform 0.2s;`;
                    box.onmouseover = () => box.style.transform = "translateX(5px)";
                    box.onmouseout = () => box.style.transform = "translateX(0)";
                    
                    box.onclick = () => {
                        const links = [{url: item.photo, title: "Class Photos", subtitle: "See what they did", icon: "📸", color: "#06b6d4"}];
                        openModal(`Children's Church: ${item.service}`, `${formatDate(item.date)}`, item.overview || "Overview coming soon!", links, `[ID:${item.id}]`);
                    };

                    box.innerHTML = `
                        <div style="color: #06b6d4; font-weight: bold; font-size: 0.85rem; text-transform: uppercase; margin-bottom: 5px;">CHILDREN'S CHURCH TODAY</div>
                        <div style="color: #cbd5e1; font-size: 0.8rem; margin-bottom: 5px;">${item.service}</div>
                        <h3 style="margin: 0; color: #fff;">Children's Church</h3>
                    `;
                }
                
                if (count >= 3) {
                    box.dataset.originalDisplay = box.style.display || 'block';
                    box.style.display = 'none';
                    hiddenElements.push(box);
                }
                container.appendChild(box);
                count++;
            });
            
            if (hiddenElements.length > 0) addViewAllButton(container, hiddenElements, count, '#ef4444');
        }
    }

    function renderStandardLists(events, kids) {
        const liveContainer = document.getElementById('live-events-container');
        const pastContainer = document.getElementById('past-events-container');
        liveContainer.innerHTML = '';
        pastContainer.innerHTML = '';
        
        const upcomingEvents = events.filter(ev => !ev.isPast).sort((a,b) => a.timestampStart - b.timestampStart);
        const pastEvents = events.filter(ev => ev.isPast).sort((a,b) => b.timestampStart - a.timestampStart);

        // LIVE EVENTS
        if(upcomingEvents.length === 0) {
            liveContainer.innerHTML = '<p style="color: #94a3b8;">No upcoming events at this time.</p>';
        } else {
            let count = 0; let hiddenElements = [];
            upcomingEvents.forEach(ev => {
                const borderColor = ev.high ? '#10b981' : '#f59e0b';
                const dateColor = ev.high ? '#10b981' : '#f59e0b';
                const timeString = ev.timeEnd ? `${formatTime(ev.timeStart)} - ${formatTime(ev.timeEnd)}` : formatTime(ev.timeStart);
                
                const box = document.createElement('div');
                box.style = `background: rgba(0, 0, 0, ${ev.high ? '0.2' : '0.1'}); border-radius: 8px; padding: 15px; margin-bottom: 15px; border-left: 4px solid ${borderColor}; cursor: pointer; transition: transform 0.2s;`;
                box.onmouseover = () => box.style.transform = "translateX(5px)";
                box.onmouseout = () => box.style.transform = "translateX(0)";
                
                box.onclick = () => {
                    const links = [
                        {url: ev.brochure, title: "Take-Home Brochure", subtitle: "Download details", icon: "📄", color: "#10b981"},
                        {url: ev.photo, title: "Shared Album", subtitle: "View memories", icon: "📸", color: "#38bdf8"}
                    ];
                    openModal(ev.title, `${formatDate(ev.date)} • ${timeString}`, ev.desc, links, `[ID:${ev.id}]`);
                };

                box.innerHTML = `
                    <div style="color: ${dateColor}; font-weight: bold; font-size: 0.85rem; text-transform: uppercase; margin-bottom: 5px;">${formatDate(ev.date)}</div>
                    <div style="color: #cbd5e1; font-size: 0.8rem; margin-bottom: 5px;">${timeString}</div>
                    <h3 style="margin: 0 0 5px 0; color: #fff;">${ev.title}</h3>
                `;
                
                if (count >= 3) {
                    box.dataset.originalDisplay = box.style.display || 'block';
                    box.style.display = 'none';
                    hiddenElements.push(box);
                }
                liveContainer.appendChild(box);
                count++;
            });
            if (hiddenElements.length > 0) addViewAllButton(liveContainer, hiddenElements, count, '#10b981');
        }

        // PAST EVENTS
        if(pastEvents.length === 0) {
            pastContainer.innerHTML = '<p style="color: #94a3b8;">No past events available.</p>';
        } else {
            let count = 0; let hiddenElements = [];
            pastEvents.forEach(ev => {
                const timeString = ev.timeEnd ? `${formatTime(ev.timeStart)} - ${formatTime(ev.timeEnd)}` : formatTime(ev.timeStart);
                const box = document.createElement('div');
                
                box.style = `background: rgba(0, 0, 0, 0.1); border-radius: 8px; padding: 15px; margin-bottom: 15px; border-left: 4px solid #475569; cursor: pointer; transition: transform 0.2s;`;
                box.onmouseover = () => box.style.transform = "translateX(5px)";
                box.onmouseout = () => box.style.transform = "translateX(0)";
                
                box.onclick = () => {
                    const links = [
                        {url: ev.brochure, title: "Take-Home Brochure", subtitle: "Download details", icon: "📄", color: "#10b981"},
                        {url: ev.photo, title: "Shared Album", subtitle: "View memories", icon: "📸", color: "#38bdf8"}
                    ];
                    openModal(ev.title, `${formatDate(ev.date)} • ${timeString}`, ev.desc, links, `[ID:${ev.id}]`);
                };

                box.innerHTML = `
                    <div style="color: #94a3b8; font-weight: bold; font-size: 0.85rem; text-transform: uppercase; margin-bottom: 5px;">${formatDate(ev.date)}</div>
                    <div style="color: #cbd5e1; font-size: 0.8rem; margin-bottom: 5px;">${timeString}</div>
                    <h3 style="margin: 0 0 5px 0; color: #fff;">${ev.title}</h3>
                `;
                
                if (count >= 3) {
                    box.dataset.originalDisplay = box.style.display || 'block';
                    box.style.display = 'none';
                    hiddenElements.push(box);
                }
                pastContainer.appendChild(box);
                count++;
            });
            if (hiddenElements.length > 0) addViewAllButton(pastContainer, hiddenElements, count, '#475569');
        }

        // CHILDREN'S CHURCH
        const ccContainer = document.getElementById('live-cc-container');
        ccContainer.innerHTML = '';
        
        const now = new Date();
        now.setHours(0,0,0,0);
        let upcomingKids = kids.filter(cc => cc.timestampStart >= now.getTime()).sort((a,b) => a.timestampStart - b.timestampStart);

        if(upcomingKids.length === 0) {
            ccContainer.innerHTML = '<p style="color: #94a3b8;">No scheduled services found.</p>';
        } else {
            let count = 0; let hiddenElements = [];
            upcomingKids.forEach(cc => {
                const box = document.createElement('div');
                box.style = `background: rgba(0, 0, 0, 0.2); border-radius: 8px; padding: 15px; margin-bottom: 15px; border-left: 4px solid #06b6d4; cursor: pointer; transition: transform 0.2s;`;
                box.onmouseover = () => box.style.transform = "translateX(5px)";
                box.onmouseout = () => box.style.transform = "translateX(0)";
                
                box.onclick = () => {
                    const links = [{url: cc.photo, title: "Class Photos", subtitle: "See what they did", icon: "📸", color: "#06b6d4"}];
                    openModal(`Children's Church: ${cc.service}`, `${formatDate(cc.date)}`, cc.overview || "Overview coming soon!", links, `[ID:${cc.id}]`);
                };

                box.innerHTML = `
                    <div style="color: #06b6d4; font-weight: bold; font-size: 0.85rem; text-transform: uppercase; margin-bottom: 5px;">${formatDate(cc.date)}</div>
                    <div style="color: #cbd5e1; font-size: 0.8rem; margin-bottom: 5px;">${cc.service}</div>
                    <h3 style="margin: 0; color: #fff;">Children's Church</h3>
                `;
                
                if (count >= 3) {
                    box.dataset.originalDisplay = box.style.display || 'block';
                    box.style.display = 'none';
                    hiddenElements.push(box);
                }
                ccContainer.appendChild(box);
                count++;
            });
            if (hiddenElements.length > 0) addViewAllButton(ccContainer, hiddenElements, count, '#06b6d4');
        }
    }

    function openModal(title, subtitle, desc, linksConfig, feedbackContext) {
        currentFeedbackContext = feedbackContext;
        document.getElementById('modal-ev-title').innerText = title;
        document.getElementById('modal-ev-time').innerText = subtitle;
        document.getElementById('modal-ev-desc').innerHTML = desc;
        document.getElementById('feedback-text').value = '';
        document.getElementById('btn-submit-feedback').innerText = 'Submit Feedback';

        const linksContainer = document.getElementById('modal-ev-links');
        linksContainer.innerHTML = '';

        const linkHTML = linksConfig.map(l => {
            if(!l.url || l.url.trim() === '') return '';
            return `
                <a href="${l.url}" target="_blank" style="display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: 8px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); text-decoration: none; padding: 20px 15px; border-radius: 12px; transition: all 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.transform='translateY(-3px)'" onmouseout="this.style.background='rgba(255,255,255,0.05)'; this.style.transform='translateY(0)'">
                    <span style="font-size: 2rem;">${l.icon}</span>
                    <strong style="color: ${l.color}; font-size: 1rem; margin-top: 5px;">${l.title}</strong>
                    <span style="color: #94a3b8; font-size: 0.75rem;">${l.subtitle}</span>
                </a>
            `;
        }).filter(Boolean).join('');

        linksContainer.innerHTML = linkHTML;
        document.getElementById('generic-view-modal').style.display = 'flex';
    }

    document.getElementById('btn-submit-feedback').onclick = async () => {
        const text = document.getElementById('feedback-text').value.trim();
        if(!text) return alert("Please type your feedback first!");
        
        const btn = document.getElementById('btn-submit-feedback');
        btn.innerText = "Sending...";
        
        try {
            const params = new URLSearchParams({ action: "submitFeedback", event: currentFeedbackContext, feedback: text });
            await fetch(`${scriptAppUrl}?${params.toString()}`, {mode:'no-cors'});
            btn.innerText = "✅ Sent!";
            setTimeout(() => { document.getElementById('generic-view-modal').style.display = 'none'; }, 2000);
        } catch (e) {
            btn.innerText = "❌ Error sending";
        }
    };

    loadData();
    document.addEventListener('astro:page-load', loadData);
</script>
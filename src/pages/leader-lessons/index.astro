---
// src/pages/leader-lessons/index.astro
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Fetch all lessons and sort them newest to oldest
const allLessons = await getCollection('lessons');
allLessons.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Lesson Archive" backLink="/leader" backText="Leader Hub" accentColor="#38bdf8">

    <div class="header" style="text-align: center; margin-bottom: 2rem;">
        <h1 style="font-size: 2.8rem; color: #38bdf8; margin: 0 0 10px 0;">Lesson Archive</h1>
        <p style="color: #cbd5e1; font-size: 1.1rem; line-height: 1.5;">Access all past lesson scripts, discussion guides, and materials.</p>
    </div>

    <div class="card" style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 16px; padding: 2rem; backdrop-filter: blur(10px);">
        
        <details class="year-folder" open style="background: rgba(0, 0, 0, 0.15); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 8px; padding: 10px; margin-bottom: 15px;">
            <summary style="cursor: pointer; font-weight: bold; color: #38bdf8; font-size: 1.2rem; display: flex; align-items: center; padding: 5px;">📁 2026 Series</summary>
            
            <ul style="list-style: none; padding: 0; margin: 10px 0 0 20px;">
                {allLessons.map(lesson => (
                    <li style="background: rgba(255, 255, 255, 0.05); margin-bottom: 8px; padding: 12px 15px; border-radius: 6px; display: flex; justify-content: space-between; align-items: center;">
                        <a href={`/leader-lessons/${lesson.slug}`} style="color: #f8fafc; text-decoration: none; font-weight: 500; font-size: 1.05rem;">{lesson.data.title}</a>
                        <span style="color: #94a3b8; font-size: 0.85rem;">
                            {lesson.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                        </span>
                    </li>
                ))}
            </ul>
        </details>

    </div>

</BaseLayout>
---
// src/pages/leader-lessons/[slug].astro
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// This tells Astro to build a page for every markdown file in the "lessons" folder
export async function getStaticPaths() {
  const lessonEntries = await getCollection('lessons');
  return lessonEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Format the date to look nice (e.g., "April 19, 2026")
const formattedDate = entry.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
---

<BaseLayout title={entry.data.title} backLink="/leader-lessons" backText="Lesson Archive" accentColor="#38bdf8">

    <div class="header" style="text-align: center; margin-bottom: 3rem;">
        <span style="display: inline-block; background: rgba(56, 189, 248, 0.2); color: #38bdf8; padding: 5px 12px; border-radius: 20px; font-size: 0.9rem; font-weight: bold; margin-bottom: 15px;">{formattedDate}</span>
        <h1 style="font-size: 3rem; color: #38bdf8; margin: 0 0 10px 0;">{entry.data.title}</h1>
        <p style="color: #cbd5e1; font-size: 1.1rem; line-height: 1.6;">{entry.data.subtitle}</p>
    </div>

    <div class="card lesson-body" style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 16px; padding: 2.5rem; backdrop-filter: blur(10px);">
        <Content />
    </div>

</BaseLayout>

<style is:global>
    /* These styles make your plain markdown look exactly like your old HTML cards! */
    .lesson-body h2 {
        color: #38bdf8;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        padding-bottom: 10px;
        margin-top: 2.5rem;
        display: flex;
        align-items: center;
        font-size: 1.8rem;
    }
    .lesson-body h2:first-child { margin-top: 0; }
    
    .lesson-body h3 { color: #f8fafc; margin-top: 1.5rem; font-size: 1.2rem; }
    
    .lesson-body p, .lesson-body ul, .lesson-body ol {
        color: #cbd5e1;
        line-height: 1.7;
        font-size: 1.05rem;
    }
    
    .lesson-body li { margin-bottom: 8px; }
    
    /* This makes Markdown blockquotes (>) look like your highlight boxes! */
    .lesson-body blockquote {
        background: rgba(0, 0, 0, 0.2);
        border-left: 4px solid #38bdf8;
        padding: 1rem 1.5rem;
        margin: 1.5rem 0;
        border-radius: 8px;
    }
    .lesson-body blockquote p { margin: 0; }
</style>
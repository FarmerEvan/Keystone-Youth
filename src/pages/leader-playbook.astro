---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Ministry Playbook" backLink="/leader" backText="Leader Hub" accentColor="#38bdf8">

    <div class="header" style="text-align: center; margin-bottom: 3rem;">
        <h1 style="font-size: 3rem; color: #38bdf8; margin: 0 0 10px 0;">Ministry Playbook</h1>
        <p style="color: #cbd5e1; font-size: 1.1rem;">The core values, expectations, and guidelines for Keystone Youth Leaders.</p>
    </div>

    <div class="card" style="border-left: 5px solid #38bdf8;">
        <h2 style="color: #f8fafc; border-bottom: 1px solid rgba(255, 255, 255, 0.1); padding-bottom: 10px; margin-top: 0;">🎯 Ministry Purposes</h2>
        
        <div style="background: rgba(0, 0, 0, 0.2); border-radius: 8px; padding: 1.5rem; border-left: 4px solid #38bdf8; margin-bottom: 1rem;">
            <h3 style="margin-top: 0; color: #fff;">Our Mission</h3>
            <p style="font-size: 1.2rem; font-style: italic; color: #38bdf8; margin: 0;">"Inspiring youth to become fully devoted followers of Christ."</p>
        </div>
        
        <ul class="rules-list" style="margin-top: 20px;">
            <li><strong>Connect with Jesus</strong></li>
            <li><strong>Connect with Others</strong></li>
            <li><strong>Connect to the Local Church</strong></li>
        </ul>
    </div>

    </BaseLayout>

<style>
    .rules-list { list-style: none; padding: 0; margin: 0; }
    .rules-list li { margin-bottom: 15px; padding: 15px; background: rgba(255, 255, 255, 0.02); border-radius: 8px; color: #cbd5e1;}
    .rules-list strong { color: #38bdf8; font-size: 1.1rem; display: block; margin-bottom: 5px; }
</style>
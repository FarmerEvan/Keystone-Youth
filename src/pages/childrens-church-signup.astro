---
import BaseLayout from '../layouts/BaseLayout.astro';

const sheetUrl = import.meta.env.PUBLIC_KIDS_CSV_URL;
const scriptAppUrl = import.meta.env.PUBLIC_SCRIPT_URL;
---

<BaseLayout title="Children's Church Sign-Up" backLink="/parent" backText="Parent Hub" accentColor="#06b6d4">

    <div class="header" style="text-align: center; margin-bottom: 3rem;">
        <h1 style="font-size: 2.8rem; color: #06b6d4; margin: 0 0 10px 0;">Children's Church Team</h1>
        <p style="color: #cbd5e1; font-size: 1.1rem; line-height: 1.5; max-width: 600px; margin: 0 auto;">Thank you for serving our kids! Click an open date to reserve it. Click a reserved date to access the lesson, upload photos, and give feedback.</p>
    </div>

    <div class="card" style="background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 16px; padding: 2rem; backdrop-filter: blur(10px);">
        <div id="signup-container">
            <p style="text-align: center; color: #94a3b8; font-style: italic;">Loading roster...</p>
        </div>
    </div>

    <div id="name-modal" class="modal-overlay" style="display: none;">
        <div class="modal-content">
            <h3 id="modal-title" style="color: #06b6d4;">Reserve Date</h3>
            <p>Please enter your first and last name:</p>
            <input type="text" id="modal-name-input" placeholder="e.g. Jane Doe" autocomplete="off" style="width: 100%; padding: 15px; margin-bottom: 20px; border-radius: 8px; border: 1px solid #475569; background: #0f172a; color: white; font-size: 1.1rem; box-sizing: border-box;" />
            <div class="modal-actions" style="display: flex; justify-content: flex-end; gap: 15px;">
                <button id="modal-cancel-btn" class="btn-cancel">Cancel</button>
                <button id="modal-confirm-btn" class="push-btn bg-cyan" style="width: auto; padding: 10px 20px; border: none; border-radius: 8px; font-weight: bold; cursor: pointer; color: #0f172a;">Confirm</button>
            </div>
        </div>
    </div>

    <div id="portal-modal" class="modal-overlay" style="display: none;">
        <div class="modal-content" style="max-width: 500px; max-height: 90vh; overflow-y: auto;">
            <h3 id="portal-title" style="color: #06b6d4; margin-top: 0; margin-bottom: 5px;">Volunteer Portal</h3>
            <p id="portal-subtitle" style="color: #94a3b8; margin-top: 0; margin-bottom: 20px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 15px;">Date & Service</p>

            <div id="portal-links" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 25px;">
                </div>

            <div style="background: rgba(0,0,0,0.2); border-radius: 12px; padding: 1.5rem; border: 1px solid rgba(255,255,255,0.05); margin-bottom: 20px;">
                <h4 style="margin: 0 0 10px 0; color: #f8fafc; font-size: 1.1rem;">💬 Leader Feedback</h4>
                <p style="margin: 0 0 15px 0; color: #94a3b8; font-size: 0.85rem;">How did the lesson go? Need any supplies for next time?</p>
                <textarea id="portal-feedback-text" rows="3" placeholder="Type your feedback here..." style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.3); color: white; font-family: inherit; margin-bottom: 10px; resize: vertical; box-sizing: border-box;"></textarea>
                <button id="btn-submit-portal-feedback" style="background: #06b6d4; color: #0f172a; border: none; padding: 10px 15px; border-radius: 8px; font-weight: bold; cursor: pointer; width: 100%; transition: opacity 0.2s;">Submit Feedback</button>
            </div>

            <div style="text-align: right;">
                <button onclick="document.getElementById('portal-modal').style.display='none'" class="btn-cancel">Close</button>
            </div>
        </div>
    </div>

</BaseLayout>

<style is:global>
    .date-row { display: flex; justify-content: space-between; align-items: center; background: rgba(0, 0, 0, 0.2); padding: 15px 20px; border-radius: 8px; margin-bottom: 10px; border-left: 4px solid #06b6d4; cursor: pointer; transition: transform 0.2s, background 0.2s; }
    .date-row:hover { transform: translateX(5px); background: rgba(0, 0, 0, 0.3); }
    .date-row.filled { border-left-color: #475569; background: rgba(255,255,255,0.02); }
    .date-info h3 { margin: 0 0 5px 0; color: #f8fafc; font-size: 1.2rem; }
    .date-info p { margin: 0; color: #94a3b8; font-size: 0.9rem; }
    
    .status-badge { background: #06b6d4; color: #0f172a; padding: 6px 12px; border-radius: 6px; font-weight: bold; font-size: 0.9rem; }
    .status-badge.filled { background: transparent; border: 1px solid #475569; color: #94a3b8; }
    
    .modal-overlay { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(8px); z-index: 9999; display: flex; align-items: center; justify-content: center; animation: fadeIn 0.2s ease-out; }
    .modal-content { background: #1e293b; border: 1px solid rgba(255,255,255,0.1); padding: 2.5rem; border-radius: 16px; width: 90%; max-width: 450px; box-shadow: 0 20px 50px rgba(0,0,0,0.8); }
    .btn-cancel { background: transparent; border: 1px solid #475569; color: #cbd5e1; padding: 10px 20px; border-radius: 8px; font-weight: bold; cursor: pointer; transition: background 0.3s; font-family: inherit; font-size: 1rem; }
    .btn-cancel:hover { background: rgba(255,255,255,0.1); color: #fff; }
    .bg-cyan { background: #06b6d4; }
    
    @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    @media (max-width: 600px) { .date-row { flex-direction: column; align-items: flex-start; gap: 10px; } .status-badge { width: 100%; text-align: center; box-sizing: border-box; } }
</style>

<script is:inline define:vars={{ SHEET_CSV_URL: sheetUrl, SCRIPT_URL: scriptAppUrl }}>
    
    let currentFeedbackContext = "";

    function parseCsvRow(row, expectedLength) {
        const c = [];
        let inQuotes = false;
        let current = '';
        for (let i = 0; i < row.length; i++) {
            const char = row[i];
            if (char === '"') inQuotes = !inQuotes;
            else if (char === ',' && !inQuotes) { c.push(current); current = ''; }
            else current += char;
        }
        c.push(current);
        const mapped = c.map(s => s.replace(/^"|"$/g, '').trim());
        while(mapped.length < expectedLength) mapped.push('');
        return mapped;
    }

    function formatDate(raw) {
        if (!raw) return '';
        if (raw.match(/^\d{4}-\d{2}-\d{2}$/)) {
            const p = raw.split('-');
            const d = new Date(p[0], p[1]-1, p[2]);
            return d.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
        }
        try {
            const d = new Date(raw);
            if (!isNaN(d)) return d.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
        } catch(e) {}
        return raw;
    }

    function getEventTimestamp(dateStr, timeStr, isEnd = false) {
        if (!dateStr) return 0;
        let d = new Date();
        if (dateStr.match(/^\d{4}-\d{2}-\d{2}$/)) {
            const p = dateStr.split('-');
            d = new Date(p[0], p[1]-1, p[2]);
        } else {
            d = new Date(dateStr);
            if (isNaN(d)) return 0;
        }
        if (timeStr) {
            const match = timeStr.trim().match(/(\d{1,2}):(\d{2})(?::\d{2})?\s*(AM|PM|am|pm)?/i);
            if (match) {
                let h = parseInt(match[1], 10);
                let m = parseInt(match[2], 10);
                let ampm = match[3] ? match[3].toLowerCase() : null;
                if (ampm === 'pm' && h < 12) h += 12;
                if (ampm === 'am' && h === 12) h = 0;
                d.setHours(h, m, 0, 0);
            } else { 
                if (isEnd) d.setHours(23, 59, 59, 999); else d.setHours(0,0,0,0);
            }
        } else { 
            if (isEnd) d.setHours(23, 59, 59, 999); else d.setHours(0,0,0,0);
        }
        return d.getTime();
    }

    async function loadChildrensChurch() {
        const container = document.getElementById('signup-container');
        try {
            const response = await fetch(`${SHEET_CSV_URL}${SHEET_CSV_URL.includes('?') ? '&' : '?'}t=${Date.now()}`);
            const text = await response.text();
            const rows = text.split('\n').slice(1);
            container.innerHTML = '';
            
            let validSpots = [];
            const now = Date.now();

            rows.forEach(row => {
                if(!row.trim()) return;
                
                const c = parseCsvRow(row, 9);
                if (!c[3]) return; 

                // Automatically discard if the service time has completely passed
                const endTimestamp = getEventTimestamp(c[0], c[2] || c[1], true);
                if (now > endTimestamp) return;

                validSpots.push({ 
                    timestamp: getEventTimestamp(c[0], c[1], false),
                    rawDate: c[0], 
                    displayDate: formatDate(c[0]), 
                    service: c[3], 
                    name: c[4], 
                    isFilled: c[5].toUpperCase() === 'TRUE', 
                    lesson: c[6], 
                    photo: c[7] 
                });
            });

            validSpots.sort((a, b) => a.timestamp - b.timestamp);

            if (validSpots.length === 0) {
                container.innerHTML = '<p style="color: #94a3b8; text-align: center;">No upcoming spots available to reserve.</p>';
                return;
            }

            validSpots.forEach(cc => {
                const rowDiv = document.createElement('div');
                rowDiv.className = `date-row ${cc.isFilled ? 'filled' : ''}`;
                
                rowDiv.onclick = () => {
                    if (cc.isFilled) openVolunteerPortal(cc);
                    else handleReservation(cc.rawDate, cc.displayDate, cc.service, rowDiv);
                };

                // Time removed from display, just service name
                rowDiv.innerHTML = `
                    <div class="date-info">
                        <h3>${cc.displayDate}</h3>
                        <p>${cc.service} ${cc.name ? `• Volunteer: <strong>${cc.name}</strong>` : ''}</p>
                    </div>
                    <span class="status-badge ${cc.isFilled ? 'filled' : ''}">${cc.isFilled ? 'View Portal' : 'Open - Reserve'}</span>
                `;
                container.appendChild(rowDiv);
            });

        } catch (error) {
            container.innerHTML = '<p style="color: #ef4444; text-align: center;">Failed to load roster.</p>';
        }
    }

    function openVolunteerPortal(cc) {
        currentFeedbackContext = `Children's Church Leader: ${cc.displayDate} - ${cc.service}`;
        document.getElementById('portal-title').innerText = "Volunteer Portal";
        document.getElementById('portal-subtitle').innerHTML = `<strong>${cc.displayDate}</strong> • ${cc.service}`;
        document.getElementById('portal-feedback-text').value = '';
        document.getElementById('btn-submit-portal-feedback').innerText = 'Submit Feedback';

        const linksContainer = document.getElementById('portal-links');
        linksContainer.innerHTML = '';

        const createActionCard = (url, title, subtitle, icon, color) => {
            if(!url || url.trim() === '') return '';
            return `
                <a href="${url}" target="_blank" style="display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; gap: 8px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); text-decoration: none; padding: 20px 15px; border-radius: 12px; transition: all 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.1)'; this.style.transform='translateY(-3px)'" onmouseout="this.style.background='rgba(255,255,255,0.05)'; this.style.transform='translateY(0)'">
                    <span style="font-size: 2rem;">${icon}</span>
                    <strong style="color: ${color}; font-size: 1rem; margin-top: 5px;">${title}</strong>
                    <span style="color: #94a3b8; font-size: 0.75rem;">${subtitle}</span>
                </a>
            `;
        };

        const linkHTML = [
            createActionCard(cc.lesson, "Lesson Material", "View curriculum", "📺", "#06b6d4"),
            createActionCard(cc.photo, "Add Photos", "Upload to shared album", "📸", "#10b981")
        ].filter(Boolean).join('');

        if (linkHTML === '') linksContainer.innerHTML = '<p style="color: #94a3b8; font-size: 0.9rem; width: 100%; text-align: center;">Resources are not yet uploaded for this week.</p>';
        else linksContainer.innerHTML = linkHTML;

        document.getElementById('portal-modal').style.display = 'flex';
    }

    async function handleReservation(rawDate, displayDate, service, rowElement) {
        const name = await askForName(displayDate);
        if (!name || name.trim() === "") return;

        const badge = rowElement.querySelector('.status-badge');
        badge.innerText = "Saving...";

        try {
            const params = new URLSearchParams({ action: "reserveVolunteerSpot", date: rawDate, service: service, name: name.trim() });
            await fetch(SCRIPT_URL + "?" + params.toString(), { method: 'GET', mode: 'no-cors' });
            loadChildrensChurch(); 
        } catch (error) {
            alert("Oops! Something went wrong.");
            badge.innerText = "Open - Reserve";
        }
    }

    function askForName(displayDate) {
        return new Promise((resolve) => {
            const modal = document.getElementById('name-modal');
            const input = document.getElementById('modal-name-input');
            const cancelBtn = document.getElementById('modal-cancel-btn');
            const confirmBtn = document.getElementById('modal-confirm-btn');

            document.getElementById('modal-title').innerText = `Reserving ${displayDate}`;
            input.value = '';
            modal.style.display = 'flex';
            input.focus();

            const cleanup = () => { modal.style.display = 'none'; cancelBtn.onclick = null; confirmBtn.onclick = null; };
            cancelBtn.onclick = () => { cleanup(); resolve(null); };
            confirmBtn.onclick = () => { cleanup(); resolve(input.value); };
            input.onkeypress = (e) => { if (e.key === 'Enter') { cleanup(); resolve(input.value); } };
        });
    }

    document.getElementById('btn-submit-portal-feedback').onclick = async () => {
        const text = document.getElementById('portal-feedback-text').value.trim();
        if(!text) return alert("Please type your feedback first!");
        
        const btn = document.getElementById('btn-submit-portal-feedback');
        btn.innerText = "Sending...";
        
        try {
            const params = new URLSearchParams({ action: "submitFeedback", event: currentFeedbackContext, feedback: text });
            await fetch(`${SCRIPT_URL}?${params.toString()}`, {mode:'no-cors'});
            btn.innerText = "✅ Sent!";
            setTimeout(() => { document.getElementById('portal-feedback-text').value = ''; btn.innerText = "Submit Feedback"; }, 3000);
        } catch (e) {
            btn.innerText = "❌ Error sending";
        }
    };

    loadChildrensChurch();
    document.addEventListener('astro:page-load', loadChildrensChurch);
</script>
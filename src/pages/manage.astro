        window.openRoom = (category) => {
            document.getElementById('admin-dashboard-view').style.display = 'none';
            document.getElementById('main-header').style.display = 'none';
            document.getElementById('admin-room-view').style.display = 'block';
            
            document.getElementById('room-title').innerText = roomConfig[category].title;
            document.getElementById('room-title').style.color = roomConfig[category].color;
            document.getElementById('room-search').value = ''; 
            
            renderRoomData(window.globalData[category]);
        };

        window.closeRoom = () => {
            document.getElementById('admin-room-view').style.display = 'none';
            document.getElementById('admin-dashboard-view').style.display = 'grid';
            document.getElementById('main-header').style.display = 'block';
        };

        function renderRoomData(items) {
            const container = document.getElementById('room-content-container');
            container.innerHTML = '';
            
            const grouped = {};
            items.forEach(item => {
                let d = new Date();
                if (item.rawDate && item.rawDate.match(/^\d{4}-\d{2}-\d{2}$/)) {
                    const p = item.rawDate.split('-');
                    d = new Date(p[0], p[1]-1, p[2]);
                } else if (item.rawDate) {
                    d = new Date(item.rawDate);
                }

                const year = d.getFullYear() || 'TBD';
                const month = d.toLocaleString('default', { month: 'long' }) || 'Unscheduled';
                
                if (!grouped[year]) grouped[year] = {};
                if (!grouped[year][month]) grouped[year][month] = [];
                grouped[year][month].push(item);
            });

            const monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];

            Object.keys(grouped).sort((a,b) => b-a).forEach(year => {
                const yearDetails = document.createElement('details');
                yearDetails.className = 'year-folder search-folder';
                yearDetails.open = true;
                yearDetails.innerHTML = `<summary>📁 ${year}</summary>`;
                
                const sortedMonths = Object.keys(grouped[year]).sort((a, b) => monthNames.indexOf(b) - monthNames.indexOf(a));
                
                sortedMonths.forEach(month => {
                    const monthDetails = document.createElement('details');
                    monthDetails.className = 'month-folder search-folder';
                    monthDetails.open = true;
                    monthDetails.innerHTML = `<summary>📂 ${month}</summary>`;
                    
                    const list = document.createElement('div');
                    list.style.marginTop = '10px';
                    
                    grouped[year][month].sort((a,b) => (b.timestamp || b.timestampStart || 0) - (a.timestamp || a.timestampStart || 0)).forEach(item => {
                        const node = createDbItem(item.title, item.subtitle, item.details, item.color, item.onEdit, item.onDelete, item.linksArray, item.feedbackTag, item.applicationsArr);
                        node.setAttribute('data-search', item.searchable.toLowerCase());
                        node.classList.add('room-item'); 
                        list.appendChild(node);
                    });
                    
                    monthDetails.appendChild(list);
                    yearDetails.appendChild(monthDetails);
                });
                container.appendChild(yearDetails);
            });
        }

        window.searchRoom = () => {
            const input = document.getElementById('room-search').value.toLowerCase();
            const items = document.getElementsByClassName('room-item');
            
            if (input !== "") { document.querySelectorAll('.search-folder').forEach(d => d.setAttribute('open', 'true')); }
            
            for (let i = 0; i < items.length; i++) {
                const searchableText = items[i].getAttribute('data-search');
                items[i].style.display = searchableText.includes(input) ? "block" : "none";
            }
        };


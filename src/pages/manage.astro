            await fetch(`${config.scriptUrl}?${params.toString()}`, {mode:'no-cors'}); window.closeModal('opp-modal'); window.refresh();
        };

        // NEW SAVE FUNCTION FOR FOOD
        const btnSaveFood = document.getElementById('btn-save-food');
        if (btnSaveFood) btnSaveFood.onclick = async () => {
            const foodId = document.getElementById('food-id').value; 


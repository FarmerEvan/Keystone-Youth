---
import BaseLayout from '../layouts/BaseLayout.astro';
import AdminDashboard from '../components/manage/AdminDashboard.astro';
import AdminRoom from '../components/manage/AdminRoom.astro';
import AdminModals from '../components/manage/AdminModals.astro';
import DatabaseItem from '../components/manage/DatabaseItem.astro';

const scriptAppUrl = import.meta.env.PUBLIC_SCRIPT_URL;
const eventsCsv = import.meta.env.PUBLIC_EVENTS_CSV_URL;
const lessonsCsv = import.meta.env.PUBLIC_LESSONS_CSV_URL;
const kidsCsv = import.meta.env.PUBLIC_KIDS_CSV_URL;
const feedbackCsv = import.meta.env.PUBLIC_FEEDBACK_CSV_URL;
const oppsCsv = import.meta.env.PUBLIC_OPPORTUNITIES_CSV_URL;
const appsCsv = import.meta.env.PUBLIC_APPLICATIONS_CSV_URL;
const prayersCsv = import.meta.env.PUBLIC_PRAYERS_CSV_URL;
const foodCsv = import.meta.env.PUBLIC_FOOD_CSV_URL; // NEW
---

<BaseLayout title="Management" backLink="/" backText="Home" accentColor="#ef4444">
    
    <div id="login-screen" class="login-overlay">
        <div class="login-card">
            <h2>Admin Login</h2>
            <input type="password" id="admin-pass" placeholder="Password" onkeypress="if(event.key === 'Enter') document.getElementById('login-btn').click()">
            <button id="login-btn">Login</button>
        </div>
    </div>

    <div class="manage-wrapper" id="main-content" style="display: none;">
        <header id="main-header">
            <h1>Ministry Command</h1>
            <p>Database & Resource Management</p>
        </header>

        <AdminDashboard />
        <AdminRoom />
        
        <AdminModals />
        <DatabaseItem />
    </div>

</BaseLayout>

<style is:global>
    .manage-wrapper { width: 100%; max-width: 1400px; margin: 0 auto; padding: 1rem; flex-direction: column; gap: 2rem; box-sizing: border-box; }
    header h1 { font-size: 2.5rem; color: #ef4444; margin: 0; text-align: center; }
    header p { color: #94a3b8; text-align: center; font-size: 0.9rem; margin-top: 5px; }
    .admin-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; width: 100%; align-items: start; }
    .dashboard-card { background: rgba(30, 41, 59, 0.7); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 1.5rem; backdrop-filter: blur(10px); display: flex; flex-direction: column; box-shadow: 0 10px 25px rgba(0,0,0,0.2); }
    .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
    .card-header h3 { margin: 0; font-size: 1.3rem; }
    .icon-btn { background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255,255,255,0.2); color: white; border-radius: 50%; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s; }
    .icon-btn:hover { background: rgba(255, 255, 255, 0.15); transform: scale(1.05); }
    .preview-list { display: flex; flex-direction: column; gap: 10px; }
    .expand-btn { background: transparent; border: 1px dashed rgba(255,255,255,0.2); color: #94a3b8; padding: 12px; border-radius: 8px; cursor: pointer; width: 100%; font-weight: bold; margin-top: 10px; transition: all 0.2s; }
    .expand-btn:hover { background: rgba(255,255,255,0.05); color: white; border-color: white; }
    .login-overlay { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: #0f172a; z-index: 10000; display: flex; align-items: center; justify-content: center; }
    .login-card { text-align: center; width: 100%; max-width: 320px; background: #1e293b; padding: 2.5rem 2rem; border-radius: 16px; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 15px 35px rgba(0,0,0,0.5); }
    .login-card h2 { margin-top: 0; margin-bottom: 20px; color: #f8fafc; }
    .login-card button { background: #ef4444; color: white; width: 100%; padding: 12px; border-radius: 8px; border: none; font-weight: bold; cursor: pointer; transition: background 0.2s; }
</style>

<script is:inline id="manage-data" data-script-url={scriptAppUrl} data-events-csv={eventsCsv} data-lessons-csv={lessonsCsv} data-kids-csv={kidsCsv} data-feedback-csv={feedbackCsv} data-opps-csv={oppsCsv} data-apps-csv={appsCsv} data-prayers-csv={prayersCsv} data-food-csv={foodCsv}>
    
    function initManageDashboard() {
        const configElement = document.getElementById('manage-data');
        if (!configElement || !document.getElementById('login-screen')) return; 
        
        const config = configElement.dataset;
        window.globalData = { kids: [], upcoming: [], past: [], lessons: [], feedback: [], opportunities: [], applications: [], prayers: [], food: [] }; 

        const todayStr = new Date().toDateString();
        function initAuth() {
            if (localStorage.getItem('keystone_admin_auth') === todayStr) {
                document.getElementById('login-screen').style.display = 'none';
                document.getElementById('main-content').style.display = 'flex';
                window.refresh();
            } else {
                document.getElementById('login-screen').style.display = 'flex';
                document.getElementById('main-content').style.display = 'none';
            }
        }

        const loginBtn = document.getElementById('login-btn');
        if (loginBtn) {
            loginBtn.onclick = () => {
                if (document.getElementById('admin-pass').value === 'keystone') {
                    localStorage.setItem('keystone_admin_auth', todayStr);
                    document.getElementById('login-screen').style.display = 'none';
                    document.getElementById('main-content').style.display = 'flex';
                    window.refresh();
                } else { alert('Incorrect password.'); }
            };
        }

        function formatDate(raw) {
            if (!raw) return '';
            if (raw.match(/^\d{4}-\d{2}-\d{2}$/)) {
                const p = raw.split('-');
                const d = new Date(p[0], p[1]-1, p[2]);
                return d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' });
            }
            try {
                const d = new Date(raw);
                if (!isNaN(d)) return d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' });
            } catch(e) {}
            return raw;
        }

        function formatTime(raw) {
            if (!raw) return '';
            const str = raw.trim();
            const match = str.match(/(\d{1,2}):(\d{2})(?::\d{2})?\s*(AM|PM|am|pm)?/i);
            if (match) {
                let h = parseInt(match[1], 10);
                let m = match[2];
                let ampm = match[3] ? match[3].toLowerCase() : null;
                if (!ampm) { ampm = h >= 12 ? 'pm' : 'am'; h = h % 12 || 12; }
                return `${h}:${m}${ampm}`;
            }
            return str;
        }

        function convertToInputTime(raw) {
            if (!raw) return '';
            const str = raw.trim();
            const match = str.match(/(\d{1,2}):(\d{2})(?::\d{2})?\s*(AM|PM|am|pm)?/i);
            if (match) {
                let h = parseInt(match[1], 10);
                let m = match[2];
                let ampm = match[3] ? match[3].toLowerCase() : null;
                if (ampm === 'pm' && h < 12) h += 12;
                if (ampm === 'am' && h === 12) h = 0;
                return `${h.toString().padStart(2, '0')}:${m}`;
            }
            return '';
        }

        function getEventTimestamp(dateStr, timeStr, isEnd = false) {
            if (!dateStr) return 0;
            let d = new Date();
            if (dateStr.match(/^\d{4}-\d{2}-\d{2}$/)) {
                const p = dateStr.split('-');
                d = new Date(p[0], p[1]-1, p[2]);
            } else {
                d = new Date(dateStr);
                if (isNaN(d)) return 0;
            }
            if (timeStr) {
                const match = timeStr.trim().match(/(\d{1,2}):(\d{2})(?::\d{2})?\s*(AM|PM|am|pm)?/i);
                if (match) {
                    let h = parseInt(match[1], 10);
                    let m = parseInt(match[2], 10);
                    let ampm = match[3] ? match[3].toLowerCase() : null;
                    if (ampm === 'pm' && h < 12) h += 12;
                    if (ampm === 'am' && h === 12) h = 0;
                    d.setHours(h, m, 0, 0);
                } else { 
                    if (isEnd) d.setHours(23, 59, 59, 999); else d.setHours(0,0,0,0);
                }
            } else { 
                if (isEnd) d.setHours(23, 59, 59, 999); else d.setHours(0,0,0,0);
            }
            return d.getTime();
        }

        function parseCsvRow(row, expectedLength) {
            const c = []; let inQuotes = false; let current = '';
            for (let i = 0; i < row.length; i++) {
                const char = row[i];
                if (char === '"') inQuotes = !inQuotes;
                else if (char === ',' && !inQuotes) { c.push(current); current = ''; }
                else current += char;
            }
            c.push(current);
            const mapped = c.map(s => s.replace(/^"|"$/g, '').trim());
            while(mapped.length < expectedLength) mapped.push('');
            return mapped;
        }

        window.openModal = (id, isEdit = false) => { 
            if (!isEdit) {
                const modal = document.getElementById(id);
                if (modal) {
                    const inputs = modal.querySelectorAll('input:not([type="button"]):not([type="submit"]):not([type="checkbox"]):not([type="hidden"]), textarea');
                    inputs.forEach(i => i.value = '');
                    const checkboxes = modal.querySelectorAll('input[type="checkbox"]');
                    checkboxes.forEach(c => c.checked = false);
                    const hiddenIds = modal.querySelectorAll('input[type="hidden"]');
                    hiddenIds.forEach(h => h.value = '');
                }
            }
            document.getElementById(id).style.display = 'flex'; 
            document.body.style.overflow = 'hidden'; 
        };

        window.closeModal = (id) => { 
            document.getElementById(id).style.display = 'none'; 
            document.body.style.overflow = ''; 
        };

        window.openViewDetailsModal = (title, links, feedbackTag, applicationsArr = null) => {
            document.getElementById('view-details-title').innerText = `${title}`;
            
            const linkSection = document.getElementById('links-section');
            const linkContainer = document.getElementById('view-links-container');
            const validLinks = links ? links.filter(l => l.url && l.url.trim() !== '') : [];
            
            if (validLinks.length === 0) {
                if(linkSection) linkSection.style.display = 'none';
            } else {
                if(linkSection) linkSection.style.display = 'block';
                linkContainer.innerHTML = '';
                validLinks.forEach(link => {
                    linkContainer.innerHTML += `
                        <a href="${link.url}" target="_blank" style="display: flex; align-items: center; gap: 15px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: ${link.color || 'white'}; text-decoration: none; padding: 12px 15px; border-radius: 8px; font-weight: bold; transition: all 0.2s;">
                            <span style="font-size: 1.5rem;">${link.icon || '🔗'}</span> <span>${link.label}</span>
                        </a>
                    `;
                });
            }

            const appsHeader = document.getElementById('apps-header');
            const appsContainer = document.getElementById('view-apps-container');
            if (applicationsArr && applicationsArr.length > 0) {
                if(appsHeader) appsHeader.style.display = 'block';
                if(appsContainer) appsContainer.style.display = 'flex';
                if(appsContainer) appsContainer.innerHTML = '';
                applicationsArr.forEach(app => {
                    appsContainer.innerHTML += `
                        <div style="background: rgba(255,255,255,0.05); padding: 10px; border-radius: 6px; border-left: 3px solid ${app.color};">
                            <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                                <strong style="color: #fff;">${app.title}</strong>
                                <span style="font-size: 0.75rem; color: ${app.color}; font-weight: bold;">${app.status}</span>
                            </div>
                            <span style="font-size: 0.75rem; color: #94a3b8; margin-bottom: 5px; display: block;">${app.contact}</span>
                            <p style="margin: 5px 0 0 0; color: #cbd5e1; font-size: 0.85rem; white-space: pre-wrap;">${app.message}</p>
                        </div>
                    `;
                });
            } else {
                if(appsHeader) appsHeader.style.display = 'none';
                if(appsContainer) appsContainer.style.display = 'none';
            }

            const fbSection = document.getElementById('feedback-section');
            const fbContainer = document.getElementById('view-feedback-container');
            
            if (!feedbackTag) {
                if(fbSection) fbSection.style.display = 'none';
            } else {
                if(fbSection) fbSection.style.display = 'block';
                fbContainer.innerHTML = '';
                const matchingFb = window.globalData.feedback.filter(fb => fb.title.includes(feedbackTag));
                if (matchingFb.length === 0) {
                    fbContainer.innerHTML = '<p style="color:#94a3b8; font-size:0.85rem; margin:0; text-align:center;">No feedback submitted yet.</p>';
                } else {
                    matchingFb.forEach(fb => {
                        fbContainer.innerHTML += `
                            <div style="background: rgba(255,255,255,0.05); padding: 10px; border-radius: 6px; border-left: 3px solid #a855f7;">
                                <span style="font-size: 0.75rem; color: #94a3b8;">${fb.subtitle}</span>
                                <p style="margin: 5px 0 0 0; color: #cbd5e1; font-size: 0.85rem; white-space: pre-wrap;">${fb.rawText}</p>
                            </div>
                        `;
                    });
                }
            }

            document.getElementById('view-details-modal').style.display = 'flex';
        };

        window.refresh = async () => {
            const fetchT = async (url) => { 
                if(!url) return ""; 
                const res = await fetch(`${url}${url.includes('?') ? '&' : '?'}t=${Date.now()}`); 
                return await res.text(); 
            };
            
            window.globalData = { kids: [], upcoming: [], past: [], lessons: [], feedback: [], opportunities: [], applications: [], prayers: [], food: [] };
            
            try {
                const [ev, les, kids, fb, opps, apps, prayers, food] = await Promise.all([
                    fetchT(config.eventsCsv), fetchT(config.lessonsCsv), fetchT(config.kidsCsv), 
                    fetchT(config.feedbackCsv), fetchT(config.oppsCsv), fetchT(config.appsCsv),
                    fetchT(config.prayersCsv), fetchT(config.foodCsv)
                ]);
                
                parseFeedback(fb); 
                parseApplications(apps); 
                parsePrayers(prayers); 
                
                parseKids(kids);
                parseEvents(ev);
                parseLessons(les);
                parseOpportunities(opps); 
                parseFood(food);
                
            } catch (error) {
                console.error("Error fetching admin data:", error);
            }
        };

        function createDbItem(title, subtitle, detailsHtml, color, onEdit, onDelete, linksArray = [], feedbackTag = null, applicationsArr = null) {
            const template = document.getElementById('db-item-template');
            const clone = template.content.cloneNode(true);
            const wrapper = clone.querySelector('.db-item');
            wrapper.style.borderLeft = `4px solid ${color}`;
            
            clone.querySelector('.t-title').innerText = title;
            clone.querySelector('.t-subtitle').innerHTML = subtitle;
            clone.querySelector('.t-details').innerHTML = detailsHtml;
            
            const validLinks = linksArray ? linksArray.filter(link => link.url && link.url.trim() !== '') : [];
            const hasApps = applicationsArr && applicationsArr.length > 0;
            
            if (validLinks.length > 0 || feedbackTag || hasApps) {
                const viewBtn = clone.querySelector('.t-view');
                viewBtn.style.display = 'block';
                
                if (hasApps) {
                    viewBtn.style.background = '#10b981';
                    viewBtn.innerText = `Apps (${applicationsArr.length})`;
                }

                viewBtn.onclick = (e) => {
                    e.stopPropagation();
                    window.openViewDetailsModal(title, linksArray, feedbackTag, applicationsArr);
                };
            }

            if (onEdit) { clone.querySelector('.t-edit').onclick = onEdit; } 
            else { clone.querySelector('.t-edit').style.display = 'none'; }
            
            clone.querySelector('.t-delete').onclick = onDelete;
            if(!onDelete) { clone.querySelector('.t-delete').style.display = 'none'; }

            return clone;
        }

        // --- PARSERS ---
        function parseKids(csv) {
            if(!csv) return;
            const rows = csv.split('\n').slice(1);
            const dashList = document.getElementById('dash-kids'); 
            if(dashList) dashList.innerHTML = '';
            
            let parsedKids = [];
            rows.forEach(row => {
                if(!row.trim()) return;
                const c = parseCsvRow(row, 10);
                if(!c[4]) return; 
                
                const id = c[0];
                const filled = (c[6] || '').toUpperCase() === 'TRUE';
                const lessonLink = c[7] || ''; 
                const photoLink = c[8] || '';
                const rawOverview = c[9] || '';
                const displayOverview = rawOverview.replace(/\\n/g, '<br>');
                const feedbackTag = `[ID:${id}]`;
                
                const links = [
                    { url: lessonLink, label: "Lesson Materials", icon: "📺", color: "#38bdf8" },
                    { url: photoLink, label: "Shared Photos", icon: "📸", color: "#10b981" }
                ];

                const statusBubble = filled 
                    ? `<span style="background: rgba(16, 185, 129, 0.15); border: 1px solid #10b981; color: #10b981; font-size: 0.65rem; padding: 2px 6px; border-radius: 12px; margin-left: 8px; vertical-align: middle; font-weight: bold; letter-spacing: 0.5px;">FILLED</span>`
                    : `<span style="background: rgba(239, 68, 68, 0.15); border: 1px solid #ef4444; color: #ef4444; font-size: 0.65rem; padding: 2px 6px; border-radius: 12px; margin-left: 8px; vertical-align: middle; font-weight: bold; letter-spacing: 0.5px;">OPEN</span>`;

                const itemObj = { 
                    rawDate: c[1], timeStart: c[2], timeEnd: c[3], title: formatDate(c[1]), 
                    subtitle: `${c[4]} ${statusBubble}`, 
                    color: '#06b6d4', searchable: `${c[1]} ${c[4]} ${c[5]} ${displayOverview}`,
                    details: `
                        <div class="detail-group"><label>Volunteer</label><p>${c[5] || 'None'}</p></div>
                        <div class="detail-group"><label>Status</label><p>${filled ? 'Reserved' : 'Open'}</p></div>
                        ${displayOverview ? `<div class="detail-group" style="grid-column:1/-1"><label>Lesson Overview</label><div class="rich-text" style="color: #cbd5e1; font-size: 0.85rem;">${displayOverview}</div></div>` : ''}
                    `,
                    onEdit: () => { 
                        document.getElementById('cc-id').value = id; 
                        document.getElementById('cc-date').value = c[1]; 
                        document.getElementById('cc-time-start').value = convertToInputTime(c[2]); 
                        document.getElementById('cc-time-end').value = convertToInputTime(c[3]); 
                        document.getElementById('cc-service').value = c[4]; 
                        document.getElementById('cc-name').value = c[5]; 
                        document.getElementById('cc-filled').checked = filled; 
                        document.getElementById('cc-lesson').value = lessonLink; 
                        document.getElementById('cc-photo').value = photoLink; 
                        document.getElementById('cc-overview').value = rawOverview.replace(/\\n/g, '\n'); 
                        window.openModal('cc-modal', true); 
                    },
                    onDelete: () => window.deleteItem('deleteVolunteerSpot', id),
                    linksArray: links,
                    feedbackTag: feedbackTag,
                    timestamp: getEventTimestamp(c[1], c[2])
                };
                parsedKids.push(itemObj);
            });

            window.globalData.kids = parsedKids.sort((a,b) => a.timestamp - b.timestamp); 

            if(dashList) {
                if (window.globalData.kids.length <= 3) { 
                    window.globalData.kids.forEach(itemObj => dashList.appendChild(createDbItem(itemObj.title, itemObj.subtitle, itemObj.details, itemObj.color, itemObj.onEdit, itemObj.onDelete, itemObj.linksArray, itemObj.feedbackTag)));
                } else {
                    window.globalData.kids.slice(0, 3).forEach(itemObj => dashList.appendChild(createDbItem(itemObj.title, itemObj.subtitle, itemObj.details, itemObj.color, itemObj.onEdit, itemObj.onDelete, itemObj.linksArray, itemObj.feedbackTag)));
                }
                const btn = document.getElementById('btn-room-kids');
                if(btn) {
                    btn.style.display = window.globalData.kids.length > 3 ? 'block' : 'none';
                    btn.innerText = `Show All (${window.globalData.kids.length}) ▾`;
                }
            }
        }

        function parseEvents(csv) {
            if(!csv) return;
            const rows = csv.split('\n').slice(1);
            const dashUp = document.getElementById('dash-upcoming');
            const dashPa = document.getElementById('dash-past');
            if(dashUp) dashUp.innerHTML = '';
            if(dashPa) dashPa.innerHTML = '';
            
            let parsedEvents = [];
            const now = Date.now();

            rows.forEach(row => {
                if(!row.trim()) return;
                const c = parseCsvRow(row, 11);
                if(!c[4]) return; 
                
                const id = c[0]; 
                const rawDesc = c[5];
                const displayDesc = rawDesc.replace(/\\n/g, '<br>');
                const endTimestamp = getEventTimestamp(c[1], c[3] || c[2], true);
                const isPast = now > endTimestamp; 
                const timeString = c[3] ? `${formatTime(c[2])} - ${formatTime(c[3])}` : formatTime(c[2]);
                const feedbackTag = `[ID:${id}]`; 

                const links = [
                    { url: c[10], label: "Leader Packet", icon: "🛡️", color: "#ef4444" },
                    { url: c[9], label: "Student Handout", icon: "✍️", color: "#facc15" },
                    { url: c[8], label: "Take-Home Brochure", icon: "📄", color: "#fb923c" },
                    { url: c[7], label: "Photo Album", icon: "📸", color: "#38bdf8" }
                ];

                const ev = {
                    rawDate: c[1], title: c[4], subtitle: formatDate(c[1]), color: isPast ? '#94a3b8' : '#fb923c', searchable: `${c[4]} ${c[1]} ${displayDesc}`,
                    details: `<div class="detail-group" style="grid-column:1/-1"><label>Description</label><div class="rich-text" style="color: #cbd5e1; font-size: 0.85rem;">${displayDesc}</div></div><div class="detail-group"><label>Time</label><p>${timeString}</p></div>`,
                    isPast: isPast,
                    timestamp: getEventTimestamp(c[1], c[2]),
                    feedbackTag: feedbackTag,
                    onEdit: () => { 
                        document.getElementById('ev-id').value = id; 
                        document.getElementById('ev-title').value = c[4]; 
                        document.getElementById('ev-date').value = c[1]; 
                        document.getElementById('ev-time-start').value = convertToInputTime(c[2]); 
                        document.getElementById('ev-time-end').value = convertToInputTime(c[3]); 
                        document.getElementById('ev-desc').value = rawDesc.replace(/\\n/g, '\n'); 
                        document.getElementById('ev-photo').value = c[7] || ''; 
                        document.getElementById('ev-brochure').value = c[8] || ''; 
                        document.getElementById('ev-handout').value = c[9] || ''; 
                        document.getElementById('ev-leader').value = c[10] || ''; 
                        document.getElementById('ev-high').checked = (c[6] || '').toUpperCase() === "TRUE"; 
                        window.openModal('ev-modal', true); 
                    },
                    onDelete: () => window.deleteItem('deleteEvent', id), 
                    linksArray: links
                };
                parsedEvents.push(ev);
            });

            window.globalData.upcoming = parsedEvents.filter(e => !e.isPast).sort((a,b) => a.timestamp - b.timestamp);
            window.globalData.past = parsedEvents.filter(e => e.isPast).sort((a,b) => b.timestamp - a.timestamp);

            if(dashUp) {
                window.globalData.upcoming.slice(0,3).forEach(ev => dashUp.appendChild(createDbItem(ev.title, ev.subtitle, ev.details, ev.color, ev.onEdit, ev.onDelete, ev.linksArray, ev.feedbackTag)));
                const btnUp = document.getElementById('btn-room-upcoming');
                if(btnUp) { btnUp.style.display = window.globalData.upcoming.length > 3 ? 'block' : 'none'; btnUp.innerText = `Show All (${window.globalData.upcoming.length}) ▾`; }
            }

            if(dashPa) {
                window.globalData.past.slice(0,3).forEach(ev => dashPa.appendChild(createDbItem(ev.title, ev.subtitle, ev.details, ev.color, ev.onEdit, ev.onDelete, ev.linksArray, ev.feedbackTag)));
                const btnPa = document.getElementById('btn-room-past');
                if(btnPa) { btnPa.style.display = window.globalData.past.length > 3 ? 'block' : 'none'; btnPa.innerText = `Show All (${window.globalData.past.length}) ▾`; }
            }
        }

        function parseLessons(csv) {
            if(!csv) return;
            const rows = csv.split('\n').slice(1).reverse();
            const dashLes = document.getElementById('dash-lessons'); 
            if(dashLes) dashLes.innerHTML = '';
            
            rows.forEach(row => {
                if(!row.trim()) return;
                const c = parseCsvRow(row, 6); 
                if(!c[2]) return; 
                
                const rawDesc = c[5] || '';

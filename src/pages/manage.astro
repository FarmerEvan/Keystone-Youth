            'kids': { title: "👦 Children's Church Archive", color: '#06b6d4' },
            'upcoming': { title: "📅 Upcoming Events Archive", color: '#fb923c' },
            'past': { title: "🕰️ Past Events Archive", color: '#94a3b8' },
            'lessons': { title: "📺 Video Lessons Archive", color: '#38bdf8' },
            'feedback': { title: "💬 Event Feedback Archive", color: '#a855f7' },
            'opportunities': { title: "🙌 Volunteer Opportunities", color: '#a855f7' },
            'applications': { title: "📥 Volunteer Applications", color: '#3b82f6' },

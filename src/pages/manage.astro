        // --- NEW FOOD PARSER ---
        function parseFood(csv) {
            if(!csv) return;
            const rows = csv.split('\n').slice(1);
            const dashList = document.getElementById('dash-food');
            if(dashList) dashList.innerHTML = '';
            
            let parsedFood = [];
            const now = Date.now();

            rows.forEach(row => {
                if(!row.trim()) return;
                const c = parseCsvRow(row, 7);
                if(!c[1]) return; // Require Date
                
                const id = c[0];
                const filled = (c[4] || '').toUpperCase() === 'TRUE';
                
                // Expiration Check (Keep active through the end of the day)
                let d = new Date();
                if (c[1].match(/^\d{4}-\d{2}-\d{2}$/)) { const p = c[1].split('-'); d = new Date(p[0], p[1]-1, p[2]); } else { d = new Date(c[1]); }
                d.setHours(23,59,59,999);
                
                // If it's a past food spot and it doesn't have feedback yet, color it Orange as a reminder!
                const isPast = now > d.getTime();
                let color = '#f59e0b'; // Default Yellow/Orange
                if (isPast && c[6]) color = '#94a3b8'; // Gray if past and has feedback
                if (!isPast && filled) color = '#10b981'; // Green if future and filled
                if (!isPast && !filled) color = '#ef4444'; // Red if future and empty
                
                const itemObj = {
                    rawDate: c[1],
                    timestamp: d.getTime(), // Use for sorting
                    title: formatDate(c[1]),
                    subtitle: filled ? `Filled: ${c[3]}` : `Needed: ${c[2] || 'Anything'}`,
                    color: color,
                    searchable: `${c[1]} ${c[2]} ${c[3]} ${c[5]} ${c[6]}`,
                    details: `
                        <div class="detail-group"><label>Needed</label><p>${c[2] || 'Anything'}</p></div>
                        <div class="detail-group"><label>Volunteer</label><p>${c[3] || 'Open'}</p></div>
                        <div class="detail-group" style="grid-column:1/-1"><label>Served</label><p>${c[5] || 'Not logged yet'}</p></div>
                        <div class="detail-group" style="grid-column:1/-1"><label>Feedback</label><p style="white-space: pre-wrap;">${c[6] || 'None'}</p></div>
                    `,
                    onEdit: () => {
                        document.getElementById('food-id').value = id;
                        document.getElementById('food-date').value = c[1];
                        document.getElementById('food-needed').value = c[2];
                        document.getElementById('food-name').value = c[3];
                        document.getElementById('food-filled').checked = filled;
                        document.getElementById('food-served').value = c[5];
                        document.getElementById('food-feedback').value = c[6];
                        window.openModal('food-modal', true);
                    },
                    onDelete: () => window.deleteItem('deleteFoodSpot', id),
                    linksArray: []
                };
                parsedFood.push(itemObj);
            });
            
            // Sort: Closest dates at the top
            window.globalData.food = parsedFood.sort((a,b) => a.timestamp - b.timestamp);
            
            if(dashList) {
                window.globalData.food.slice(0,3).forEach(food => dashList.appendChild(createDbItem(food.title, food.subtitle, food.details, food.color, food.onEdit, food.onDelete)));
                const btn = document.getElementById('btn-room-food');
                if(btn) {
                    btn.style.display = window.globalData.food.length > 3 ? 'block' : 'none';
                    btn.innerText = `Show All (${window.globalData.food.length}) ▾`;
                }
            }
        }

        async function updateAppStatus(timestamp, name, status) {
            const params = new URLSearchParams({ action: "updateAppStatus", timestamp: timestamp, name: name, status: status });
            await fetch(`${config.scriptUrl}?${params.toString()}`, {mode:'no-cors'});
            setTimeout(window.refresh, 1000);
        }


                const itemObj = {
                    rawDate: c[0], title: c[2], subtitle: `${formatDate(c[0])} - ${formatDate(c[1])}`, color: '#38bdf8', searchable: `${c[2]} ${c[0]} ${c[4]} ${displayDesc}`,
                    details: `
                        <div class="detail-group"><label>YouTube ID</label><p>${c[4]}</p></div>

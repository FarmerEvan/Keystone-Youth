        function parseFeedback(csv) {
            if(!csv) return;
            const rows = csv.split('\n').slice(1).reverse(); 
            const dashList = document.getElementById('dash-feedback'); 
            if(dashList) dashList.innerHTML = '';
            
            let parsedFb = [];

            rows.forEach(row => {
                if(!row.trim()) return;
                const c = parseCsvRow(row, 3);
                if(!c[1]) return;
                
                let dateObj = new Date();
                if(c[0]) { dateObj = new Date(c[0]); }
                const dateRaw = dateObj.toLocaleDateString();
                
                const itemObj = { 
                    rawDate: dateObj.toISOString().split('T')[0], title: c[1], subtitle: dateRaw, color: '#a855f7', searchable: `${c[1]} ${c[2]}`,
                    rawText: c[2], 
                    details: `<div class="detail-group"><label>Feedback</label><p style="white-space: pre-wrap;">${c[2]}</p></div>`,
                    onEdit: null, onDelete: null, linksArray: [], timestamp: dateObj.getTime()
                };
                
                parsedFb.push(itemObj);
            });
            
            window.globalData.feedback = parsedFb.sort((a,b) => b.timestamp - a.timestamp);
            
            if (window.globalData.feedback.length <= 3 && dashList) { 
                window.globalData.feedback.forEach(fb => dashList.appendChild(createDbItem(fb.title, fb.subtitle, fb.details, fb.color, null, null, []))); 
            } else if (dashList) {
                window.globalData.feedback.slice(0,3).forEach(fb => dashList.appendChild(createDbItem(fb.title, fb.subtitle, fb.details, fb.color, null, null, []))); 
            }

            const btn = document.getElementById('btn-room-feedback');
            if(btn) {
                btn.style.display = window.globalData.feedback.length > 3 ? 'block' : 'none';
                btn.innerText = `Show All (${window.globalData.feedback.length}) ▾`;
            }
        }

        function parseOpportunities(csv) {
            if(!csv) return;
            const rows = csv.split('\n').slice(1);
            const dashList = document.getElementById('dash-opportunities');
            if(dashList) dashList.innerHTML = '';
            
            let parsedOpps = [];
            rows.forEach(row => {
                if(!row.trim()) return;
                const c = parseCsvRow(row, 9); 
                if(!c[1]) return; 
                
                const id = c[0];
                const isActive = (c[7] || '').toUpperCase() === 'TRUE';
                
                const targets = [];
                if((c[3]||'').toUpperCase() === 'TRUE') targets.push('Parents');
                if((c[4]||'').toUpperCase() === 'TRUE') targets.push('Students');
                if((c[5]||'').toUpperCase() === 'TRUE') targets.push('Leaders');
                if((c[6]||'').toUpperCase() === 'TRUE') targets.push('Helpers');
                
                const roleApps = window.globalData.applications.filter(app => app.roleTitle === c[1]);

                const itemObj = {
                    id: id,
                    rawDate: new Date().toISOString(), 
                    title: c[1],
                    subtitle: isActive ? "🟢 Actively Recruiting" : "🔴 Closed",
                    color: '#a855f7',
                    searchable: `${c[1]} ${c[2]}`,
                    details: `
                        <div class="detail-group"><label>Displayed To</label><p>${targets.join(', ') || 'Nobody'}</p></div>
                        <div class="detail-group" style="grid-column:1/-1"><label>Description</label><div class="rich-text" style="color: #cbd5e1; font-size: 0.85rem;">${c[2].replace(/\\n/g, '<br>')}</div></div>
                    `,
                    onEdit: () => {
                        document.getElementById('opp-id').value = id;
                        document.getElementById('opp-title').value = c[1];
                        document.getElementById('opp-desc').value = c[2].replace(/\\n/g, '\n');
                        document.getElementById('opp-parents').checked = (c[3]||'').toUpperCase() === 'TRUE';
                        document.getElementById('opp-students').checked = (c[4]||'').toUpperCase() === 'TRUE';
                        document.getElementById('opp-leaders').checked = (c[5]||'').toUpperCase() === 'TRUE';
                        document.getElementById('opp-helpers').checked = (c[6]||'').toUpperCase() === 'TRUE';
                        document.getElementById('opp-active').checked = isActive;
                        document.getElementById('opp-questions').value = (c[8]||'').replace(/\\n/g, '\n'); 
                        window.openModal('opp-modal', true);
                    },
                    onDelete: () => window.deleteItem('deleteOpportunity', id),
                    linksArray: [],
                    applicationsArr: roleApps 
                };
                parsedOpps.push(itemObj);
            });
            
            window.globalData.opportunities = parsedOpps;
            
            if(dashList) {
                parsedOpps.slice(0,3).forEach(opp => dashList.appendChild(createDbItem(opp.title, opp.subtitle, opp.details, opp.color, opp.onEdit, opp.onDelete, opp.linksArray, null, opp.applicationsArr)));
                const btn = document.getElementById('btn-room-opportunities');
                if(btn) {
                    btn.style.display = parsedOpps.length > 3 ? 'block' : 'none';
                    btn.innerText = `Show All (${parsedOpps.length}) ▾`;
                }
            }
        }

        function parseApplications(csv) {
            if(!csv) return;
            const rows = csv.split('\n').slice(1).reverse(); 
            const dashList = document.getElementById('dash-applications');
            if(dashList) dashList.innerHTML = '';
            
            let parsedApps = [];
            rows.forEach(row => {
                if(!row.trim()) return;
                const c = parseCsvRow(row, 6);
                if(!c[1]) return; 
                
                const timestamp = c[0];
                const status = c[5] || 'New';
                
                let color = '#3b82f6'; 
                if (status === 'Contacted') color = '#f59e0b'; 
                if (status === 'Approved') color = '#10b981'; 
                
                const itemObj = {
                    rawDate: timestamp,
                    title: c[1],
                    subtitle: `${c[3]} • Status: ${status}`,
                    roleTitle: c[3], 
                    color: color,
                    status: status, 
                    contact: c[2], 
                    message: c[4].replace(/\\n/g, '\n'), 
                    searchable: `${c[1]} ${c[2]} ${c[3]}`,
                    details: `
                        <div class="detail-group"><label>Contact Info</label><p>${c[2]}</p></div>
                        <div class="detail-group" style="grid-column:1/-1"><label>Application Answers</label><p style="white-space: pre-wrap;">${c[4].replace(/\\n/g, '\n')}</p></div>
                    `,
                    onEdit: () => {
                        const newStatus = prompt("Update Status (Type exactly: New, Contacted, or Approved):", status);
                        if (newStatus && ['New', 'Contacted', 'Approved'].includes(newStatus)) {
                            updateAppStatus(timestamp, c[1], newStatus);
                        } else if (newStatus) {
                            alert("Action canceled. Please type exactly 'New', 'Contacted', or 'Approved'.");
                        }
                    },
                    onDelete: null, 
                    linksArray: []
                };
                parsedApps.push(itemObj);
            });
            
            window.globalData.applications = parsedApps;
            
            if(dashList) {
                parsedApps.slice(0,3).forEach(app => dashList.appendChild(createDbItem(app.title, app.subtitle, app.details, app.color, app.onEdit, app.onDelete)));
                const btn = document.getElementById('btn-room-applications');
                if(btn) {
                    btn.style.display = parsedApps.length > 3 ? 'block' : 'none';
                    btn.innerText = `Show All (${parsedApps.length}) ▾`;
                }
            }
        }


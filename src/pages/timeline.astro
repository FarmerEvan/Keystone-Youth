---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Chronological Bible Plan" backLink="/" backText="Home" accentColor="#d97706">

    <div class="header" style="text-align: center; margin-bottom: 2rem;">
        <h1 style="font-size: 2.8rem; color: #d97706; margin: 0 0 10px 0;">Chronological Bible Plan</h1>
        <p style="color: #cbd5e1; font-size: 1.1rem;">Experience the grand story of Scripture in the order it actually happened.</p>
    </div>

    <div style="background: rgba(217, 119, 6, 0.1); border-left: 4px solid #d97706; padding: 1.5rem; border-radius: 0 12px 12px 0; margin-bottom: 2rem;">
        <p style="margin: 0; color: #fdf6e3; line-height: 1.5; font-size: 1.05rem;"><strong>1-Year Plan:</strong> These readings are compiled according to recent historical research. If the schedule provided is followed, the entire Bible will be read in one calendar year!</p>
    </div>

    <details>
        <summary>Part 1: Days 1 - 50 (Beginnings & The Exodus)</summary>
        <ul class="reading-list">
            <li class="reading-item"><span class="day-num">Day 1:</span> Genesis 1-3</li>
            <li class="reading-item"><span class="day-num">Day 2:</span> Genesis 4-7</li>
            <li class="reading-item"><span class="day-num">Day 30:</span> Exodus 1-3</li>
            <li class="reading-item"><span class="day-num">Day 50:</span> Leviticus 19-21</li>
        </ul>
    </details>

</BaseLayout>

<style>
    details { background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 12px; margin-bottom: 15px; transition: all 0.3s ease; backdrop-filter: blur(10px); }
    details[open] { background: rgba(0, 0, 0, 0.3); padding-bottom: 10px; }
    summary { cursor: pointer; font-weight: bold; color: #fbbf24; font-size: 1.3rem; outline: none; display: flex; align-items: center; padding: 15px 20px; }
    summary::before { content: '📖 '; margin-right: 15px; font-size: 1.5rem; }
    details[open] > summary::before { content: '📜 '; }
    
    .reading-list { list-style: none; padding: 0 20px; margin: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 10px; }
    .reading-item { background: rgba(0, 0, 0, 0.2); padding: 10px 15px; border-radius: 6px; border-left: 2px solid #d97706; font-size: 1rem; color: #f8fafc; display: flex; align-items: center; }
    .day-num { color: #d97706; font-weight: bold; margin-right: 10px; min-width: 55px; }

    @media (max-width: 600px) { .reading-list { grid-template-columns: 1fr; } }
</style>